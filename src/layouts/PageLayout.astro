---
import Layout from './Layout.astro';
import Footer from '../components/Footer.astro';
import MapBackdrop from '../components/MapBackdrop.astro';
import StationBoard from '../components/StationBoard.astro';
import TransitThemeSwitch from '../components/TransitThemeSwitch.astro';

interface Props {
  title: string;
  description: string;
  lineId: 'music' | 'projects' | 'about';
  hex: string;
  signName: string;
  ogImage?: string;
}
const { title, description, lineId, hex, signName, ogImage } = Astro.props;
// `signName` is the short label shown centred in the coloured sign-header bar.
---
<Layout title={title} description={description} ogImage={ogImage} bodyClass={`page page-${lineId}`}>
  <!-- Same docked Destinations rail as the map/platform views (fixed
       full-height; placement in global.css `body.page #station-board`).
       Its links are ordinary page navigations back to the platforms. -->
  <StationBoard />
  <div id="tt-page-shell">
    <MapBackdrop lineId={lineId} />
    <header class="sign-header" style={`background:${hex}; --sign-vt: sign-${lineId};`}>
      <a class="logo" href="/transit" aria-label="rohan.jk — home">
        <img src="/logo.svg" width="34" height="34" alt="" />
        <span class="logo-name">rohan.jk</span>
      </a>
      <h1 class="sign-title">{signName}</h1>
      <div class="sign-header-actions">
        <a class="sign-pill sign-back" href={`/transit/${lineId}`}>&lsaquo; back</a>
        <TransitThemeSwitch />
      </div>
    </header>
    <main id="tt-main" class="page-body">
      <span class="spine" style={`background:${hex}`} aria-hidden="true">
        <span class="station-here" aria-hidden="true"></span>
      </span>
      <slot />
    </main>
    <Footer />
  </div>
</Layout>

<style>
  /* This page's station on its line: white capsule with ink ring at the top
     of the spine, matching the map's transfer-station mark. */
  .station-here {
    position: absolute;
    top: 2.2rem;
    left: 50%;
    transform: translateX(-50%);
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: #fff;
    border: 5px solid var(--ink);
    box-sizing: border-box;
  }
  .spine { position: relative; }
</style>

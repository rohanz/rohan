---
import Analytics from '../components/Analytics.astro';
import '../styles/default.css';
import '../styles/default-phase2.css';
import { ClientRouter } from 'astro:transitions';
import { transitPathFor } from '../lib/theme-paths';

interface Props {
  title: string;
  description: string;
  section?: 'homepage' | 'music' | 'projects' | 'about' | 'none';
  ogImage?: string;
  canonicalPath?: string;
  mainClass?: string;
  robots?: string;
}

const {
  title,
  description,
  section = 'homepage',
  ogImage = '/assets/images/og.png',
  canonicalPath = Astro.url.pathname,
  mainClass = '',
  robots = 'index, follow',
} = Astro.props;
const canonical = new URL(canonicalPath, Astro.site).href;
const ogAbs = new URL(ogImage, Astro.site).href;
const activeSection = section === 'homepage' ? undefined : section;
const transitHref = transitPathFor(Astro.url.pathname);
const personLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'rohan.jk',
  description: 'Computer engineering student building end-to-end products with AI',
  url: 'https://www.rohanjk.xyz',
  sameAs: [
    'https://github.com/rohanz',
    'https://www.instagram.com/rrohan.jk/',
    'https://open.spotify.com/artist/3I1V2FxqX2qs3zrUY0fCPp',
  ],
  jobTitle: 'Software Developer',
  affiliation: { '@type': 'Organization', name: 'Nanyang Technological University' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': 'https://www.rohanjk.xyz' },
});
---
<!doctype html>
<html lang="en" class="theme-default">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="rohan.jk, computer engineering, software developer, ai, machine learning, ntu singapore, portfolio, projects, indie pop" />
    <meta name="author" content="rohan.jk" />
    <meta name="robots" content={robots} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="rohan.jk" />
    <meta property="og:image" content={ogAbs} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogAbs} />

    <meta name="theme-color" content="#1a1a2e" />
    <meta name="msapplication-TileColor" content="#1a1a2e" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />
    <link rel="stylesheet" href="/fonts/fonts.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" integrity="sha384-3B6NwesSXE7YJlcLI9RpRqGf2p/EgVH8BgoKTaUrmKNDkHPStTQ3EyoYjCGXaOTS" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <script is:inline>
      // Apply the saved theme before first paint. Leaving this to theme.js
      // (end of body) painted the first frames dark, then flipped data-theme
      // mid-entrance — a full-document restyle that dropped frames while the
      // sidebar slid in, plus a visible dark flash in light mode. ClientRouter
      // swaps replace <html> attributes, so re-apply after each swap too.
      (function () {
        var apply = function () {
          try {
            var saved = localStorage.getItem('default:theme');
            if (saved) document.documentElement.setAttribute('data-theme', saved);
          } catch (e) { /* storage unavailable */ }
        };
        apply();
        document.addEventListener('astro:after-swap', apply);
      })();
    </script>
    <script is:inline type="application/ld+json" set:html={personLd}></script>
    <ClientRouter />
    <Analytics />
  </head>
  <body>
    <a href="#mainContent" class="skip-nav">Skip to content</a>
    <div id="routeAnnouncer" class="sr-only" role="status" aria-live="polite" aria-atomic="true"></div>
    <canvas id="asciiGrid" class="ascii-grid" aria-hidden="true"></canvas>
    <div class="noise-overlay" aria-hidden="true"></div>
    <div class="container">
      <nav class="sidebar" id="sidebar" aria-label="Primary" transition:persist="classic-sidebar">
        <div class="logo"><h1><a class="logo-link" href="/" aria-label="rohan.jk - home">rohan.jk</a></h1></div>
        <ul class="nav-menu">
          <li class="nav-item"><a class:list={["nav-link magnetic-target", { active: activeSection === 'music' }]} aria-current={activeSection === 'music' ? 'page' : undefined} href="/music" data-section="music">music</a></li>
          <li class="nav-item"><a class:list={["nav-link magnetic-target", { active: activeSection === 'projects' }]} aria-current={activeSection === 'projects' ? 'page' : undefined} href="/projects" data-section="projects">projects</a></li>
          <li class="nav-item"><a class:list={["nav-link magnetic-target", { active: activeSection === 'about' }]} aria-current={activeSection === 'about' ? 'page' : undefined} href="/about" data-section="about">about me</a></li>
        </ul>
      </nav>

      <nav class="site-controls" aria-label="Site theme controls">
        <button class="theme-toggle contact-link" id="themeToggle" aria-label="Toggle light/dark theme"><i class="fas fa-sun" aria-hidden="true"></i></button>
        <a class="site-switch-link" href={transitHref} data-theme-pref="transit">
          <svg class="site-switch-glyph" viewBox="0 0 28 16" aria-hidden="true">
            <path d="M3 8h22"></path>
            <circle cx="3" cy="8" r="2.2"></circle>
            <circle cx="14" cy="8" r="2.2"></circle>
            <circle cx="25" cy="8" r="2.2"></circle>
          </svg>
          <span>transit mode</span>
        </a>
      </nav>

      <main class:list={["main-content", mainClass]} id="mainContent">
        <slot />
      </main>

      <div class:list={["floating-contact", section === 'homepage' ? 'homepage-active' : 'show']} id="floatingContact" role="region" aria-label="Social links">
        <div class="contact-item"><a href="https://www.instagram.com/rrohan.jk/" class="contact-link" target="_blank" rel="noopener noreferrer" aria-label="Instagram"><i class="fab fa-instagram" aria-hidden="true"></i></a></div>
        <div class="contact-item"><a href="https://open.spotify.com/artist/3I1V2FxqX2qs3zrUY0fCPp?si=SiJ7DZ_xQXiNG9uy_G1SsQ" class="contact-link" target="_blank" rel="noopener noreferrer" aria-label="Spotify"><i class="fab fa-spotify" aria-hidden="true"></i></a></div>
        <div class="contact-item"><a href="https://github.com/rohanz" class="contact-link" target="_blank" rel="noopener noreferrer" aria-label="GitHub"><i class="fab fa-github" aria-hidden="true"></i></a></div>
        <div class="contact-item"><a href="https://www.linkedin.com/in/rohan-jk" class="contact-link" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"><i class="fab fa-linkedin-in" aria-hidden="true"></i></a></div>
      </div>
    </div>
    <audio id="audio-player" preload="metadata"></audio>
    <script>
      import '../scripts/default/index.ts';
      import '../lib/theme-switch.ts';
    </script>
  </body>
</html>

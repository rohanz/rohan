---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection, render } from 'astro:content';
import { getProjectNav, type NavItem } from '../../lib/projectNav';
import { lineById } from '../../data/system';

export async function getStaticPaths() {
  const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
  // Unlisted projects still get a built page, but they don't participate in
  // the prev/next chain: `ordered` (which drives getProjectNav) holds listed
  // entries only, so an unlisted page shows no prev/next and no listed page
  // ever links to it.
  const ordered = projects
    .filter((p) => !p.data.unlisted)
    .map((p) => ({ slug: p.id, title: p.data.title })) as NavItem[];
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project, ordered },
  }));
}

const { project, ordered } = Astro.props;
const { Content, headings } = await render(project);
const { prev, next } = getProjectNav(ordered, project.id);
const line = lineById('projects');
// TOC covers h2/h3 of the article body only — no h1/title, and nothing
// before the first h2 (a leading h3 would float above the line's first stop).
const h2h3 = headings.filter((h) => h.depth === 2 || h.depth === 3);
const firstH2 = h2h3.findIndex((h) => h.depth === 2);
const sections = firstH2 === -1 ? [] : h2h3.slice(firstH2);
---
<PageLayout
  title={`${project.data.title} — rohan.jk`}
  description={project.data.summary}
  lineId="projects"
  hex={line.hex}
  signName={project.data.barTitle ?? project.data.title}
  ogImage={project.data.image}
>
  <div class="article-layout">
    {sections.length > 0 && (
      <nav class="train-toc" aria-label="section navigation">
        <div class="toc-inner">
          <svg class="toc-rail" aria-hidden="true"></svg>
          <ol>
            {sections.map((h) => (
              <li class={h.depth === 3 ? 'sub' : ''} data-depth={h.depth}>
                <a href={`#${h.slug}`} data-target={h.slug}>
                  <span class="toc-label">{h.text}</span>
                </a>
              </li>
            ))}
          </ol>
        </div>
        <div class="toc-nav">
          {prev && (
            <a class="toc-nav-link toc-nav-prev" href={`/projects/${prev.slug}`} data-astro-prefetch="hover"><span class="nav-arrow">‹</span>prev</a>
          )}
          <a class="toc-nav-link" href="/projects">all projects</a>
          {next && (
            <a class="toc-nav-link toc-nav-next" href={`/projects/${next.slug}`} data-astro-prefetch="hover">next<span class="nav-arrow">›</span></a>
          )}
        </div>
      </nav>
    )}

    <article class="article">
      <img class="article-banner" src={project.data.image} alt={`${project.data.title} banner`} />
      <header class="article-header">
        <h1 class="article-title">{project.data.title}</h1>
        <p class="article-summary">{project.data.summary}</p>
      </header>
      <Content />

      <nav class="stop-nav" aria-label="project navigation">
        {prev ? <a class="prev" href={`/projects/${prev.slug}`} data-astro-prefetch="hover">← previous stop<span>{prev.title}</span></a> : <span></span>}
        <a class="to-line" href="/projects">back to projects</a>
        {next ? <a class="next" href={`/projects/${next.slug}`} data-astro-prefetch="hover">next stop →<span>{next.title}</span></a> : <span></span>}
      </nav>
    </article>
  </div>
</PageLayout>

<script>
  import '../../scripts/article.ts';
  import '../../scripts/article-widgets.ts';
</script>

<style>
  .article-layout { position: relative; display: grid; grid-template-columns: 1fr; justify-items: center; }
  /* Reading column + body size match the original site's detail page exactly:
     a 760px column (was the original's 800 — trimmed a step for readability, Rohan's call) with 1.25rem (20px) / 1.7 body text. Headings/title/summary
     set their own sizes below, so only paragraphs & lists inherit this. */
  .article { max-width: 760px; width: 100%; min-width: 0; font-size: 1.25rem; line-height: 1.7; }
  /* Geometry replicated from the ORIGINAL site's detail view (--detail-half):
     the article column is VIEWPORT-centred once the viewport is wide enough,
     and the TOC floats centred in the gutter between the destinations rail
     and the article — equal air on both of its sides (--half = half the free
     space between the rail and a viewport-centred 760px article, after the
     212px TOC). When the viewport is too narrow to centre (--half negative;
     with a 300px rail that's everything below ~2080px) the max() clamps take
     over exactly like the original's: the TOC sits one content-pad (--cpad,
     3.5vw — the original's gutter token) right of the rail and the article
     clears the TOC column by 4rem — the original's measured 64.0px gap at
     both 1440 and 1280 (its .detail-content-column margin-left reserves
     `210px + 4rem` past the fixed TOC). The max() against the pure centred
     position (50vw - 380px) is also the rail-collision guard: the article's
     left edge can never fall below rail + cpad + toc width + 4rem, so the centred
     column can't slide under the rail. */
  .article-layout {
    /* 248px column = a 216px label measure at the 1.15rem type, so all but
       the longest section titles hold ONE line (the original's measure is
       194px — anything that wraps here wraps there too). */
    --toc-w: 248px;
    --cpad: clamp(1.5rem, 3.5vw, 4rem);
    --half: calc((50vw - var(--rail-w, 0px) - var(--toc-w) - 380px) / 2);
    /* One shared gutter on BOTH sides of the TOC (rail→TOC and TOC→article are
       always equal — Rohan's laptop-round call, replacing the fixed 4rem body
       gap). --half is exactly the gutter that puts a 760px article at the
       viewport centre, so wide screens keep the centred column; when that
       would squeeze below --cpad (laptops), the article slides left toward
       the TOC instead and the two gutters stay symmetric. */
    --gutter: max(var(--cpad), var(--half));
    --toc-left: calc(var(--rail-w, 0px) + var(--gutter));
    --article-left: calc(var(--toc-left) + var(--toc-w) + var(--gutter));
  }
  @media (min-width: 1000px) {
    .article-layout { justify-items: start; }
    .article {
      /* --article-left is a viewport coordinate; the page-body is uncapped on
         detail pages (see the :has() rule in the global block) so it starts
         at x=0 — subtract only its own left padding to get the margin. */
      margin-left: calc(var(--article-left) - clamp(1rem, 4vw, 3rem));
      max-width: min(760px, calc(100vw - var(--article-left) - 2.5rem));
    }
  }

  .article-banner {
    width: 100%; height: auto; border-radius: var(--radius);
    margin: 0 0 2rem; box-shadow: 0 8px 30px rgba(0,0,0,0.12);
  }

  /* Title + blurb under the banner (mirrors the original site's detail header:
     a large accent-coloured title, then an italic dimmed summary). The coloured
     sign-header bar now carries only the short barTitle label. */
  .article-header { margin: 0 0 2.4rem; }
  .article-title {
    font-size: 2.2rem; font-weight: 800; line-height: 1.15;
    color: var(--line-projects); margin: 0 0 0.75rem;
  }
  .article-summary {
    font-size: 1.2rem; font-weight: 500; font-style: italic;
    line-height: 1.6; color: var(--muted); margin: 0;
  }
  @media (max-width: 560px) { .article-title { font-size: 1.8rem; } }

  /* Heading sizes match the original site's detail body exactly. */
  .article :global(h2) { font-size: clamp(1.45rem, 2.6vw, 2rem); font-weight: 750; margin-top: 2.4rem; scroll-margin-top: 90px; }
  .article :global(h3) { font-size: clamp(1.12rem, 1.8vw, 1.35rem); font-weight: 700; margin-top: 1.6rem; }
  /* Images: centred, not left-aligned. Ones narrower than the column keep their
     natural size and sit centred; wide ones cap at the column width. */
  .article :global(img) {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 1.5rem auto;
    border-radius: var(--radius);
    box-shadow: 0 6px 24px rgba(0,0,0,0.08);
    cursor: zoom-in;
  }
  /* Code blocks WRAP to the column instead of scrolling horizontally (matches the
     original site — long lines fold rather than forcing a scrollbar). */
  .article :global(pre) { max-width: 100%; box-sizing: border-box; overflow-x: auto; }
  .article :global(pre code) { white-space: pre-wrap; overflow-wrap: anywhere; word-break: break-word; }
  .article :global(.article-banner) { cursor: zoom-in; }
  .article :global(a:not(.try-it-btn):not(.support-btn)) { color: var(--line-projects); }
  .article :global(table) { border-collapse: collapse; width: 100%; margin: 1.5rem 0; font-size: 0.92rem; }
  .article :global(th), .article :global(td) { border: 1px solid rgba(0,0,0,0.12); padding: 0.5rem 0.7rem; text-align: left; }

  /* Train-line table of contents. The rail is one octilinear SVG path in the
     line color (drawn by src/scripts/article.ts after layout): it runs
     vertically past the h2 ticks, jogs 18px right at 45° for h3 runs, and
     steps back out when h2s resume — like the map's route geometry. Ticks are
     SVG circles on the path; the current one's fill transitions white→amber
     flush against the ink ring (SVG fill meets the stroke's inner edge, so
     there is no white sliver). Active state changes fill/color only — never a
     layout property — so passing a section never nudges the rail. */
  .train-toc { display: none; }
  @media (min-width: 1000px) {
    .train-toc {
      /* A full-height flex column: the section list sits at the top and the
         prev/all-projects/next nav is pinned to the BOTTOM (margin-top:auto), so
         it holds a fixed spot on screen regardless of the TOC's length — like the
         original site's sidebar. */
      display: flex;
      flex-direction: column;
      position: fixed;
      /* top is set from the banner's edge by article.ts; this is the pre-JS
         default (header + page-body padding) to avoid a first-paint jump. */
      top: 11rem;
      /* End the rail a small fixed margin above the viewport bottom so the
         prev/next nav (pinned to the bottom via margin-top:auto) holds ONE fixed
         spot regardless of the TOC's length — it never shifts when you page
         between projects — while sitting low enough to leave the section list
         maximum room on short screens. */
      bottom: 2.5rem;
      /* Centred in the rail↔article gutter (or a content-pad off the rail
         when the gutter is tight) — computed on .article-layout, inherited
         here. Viewport coordinate, matching this element's fixed positioning. */
      left: var(--toc-left);
      width: var(--toc-w, 248px);
      z-index: 5;
    }
  }
  .train-toc .toc-inner { position: relative; flex: 0 1 auto; min-height: 0; overflow-y: auto; scrollbar-width: none; }
  /* Scroll affordance for short screens: when the list overflows (article.ts
     toggles .is-scrollable), fade its bottom edge so it reads as "more below"
     instead of cut off mid-item. Fade lifts once scrolled to the end via the
     mask staying put — the last item scrolls up out of the faded band. */
  .train-toc .toc-inner.is-scrollable {
    mask-image: linear-gradient(to bottom, black calc(100% - 26px), transparent);
    -webkit-mask-image: linear-gradient(to bottom, black calc(100% - 26px), transparent);
  }
  .train-toc .toc-inner::-webkit-scrollbar { display: none; }
  .train-toc :global(.toc-rail) { position: absolute; top: 0; left: 0; width: 44px; pointer-events: none; }
  .train-toc :global(.toc-rail path) {
    fill: none; stroke: var(--line-projects); stroke-width: 3.2;
    stroke-linejoin: round; stroke-linecap: round; opacity: 0.9;
  }
  .train-toc :global(.toc-rail circle) {
    fill: #fff; stroke: var(--ink); cursor: pointer; pointer-events: auto;
    transition: fill 0.45s ease;
  }
  .train-toc :global(.toc-rail circle.is-current) { fill: #f9c25e; }
  .train-toc ol { list-style: none; margin: 0; padding: 0.4rem 0; position: relative; }
  /* Type mirrors the ORIGINAL site's sidebar exactly: h2 links 1.15rem,
     h3 (sub) links 0.95rem, weight 600 — compact through spacing, not tiny type. */
  .train-toc li { position: relative; margin: 0 0 0.85rem; }
  .train-toc li:last-child { margin-bottom: 0; }
  .train-toc a {
    display: block; text-decoration: none; color: var(--muted);
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 1.15rem; font-weight: 600; line-height: 1.2;
    padding-left: 32px;
  }
  .train-toc li.sub a { font-size: 0.95rem; padding-left: 48px; }
  .train-toc a:hover .toc-label { color: var(--ink); }
  .train-toc a.is-current .toc-label { color: var(--ink); }
  /* Parent h2 stays inked while one of its h3s is current (original's
     parent-active), keeping the section context visible in the rail. */
  .train-toc a.is-parent .toc-label { color: var(--ink); }

  /* Prev / all projects / next, in the left rail (desktop) — mirrors the original
     site's minimal sidebar nav (three lowercase links, dimmed until hover). The
     bottom .stop-nav is hidden on desktop and kept only for narrow screens where
     the rail itself is hidden. */
  .toc-nav {
    margin-top: auto;
    padding-top: 1.2rem;
    /* No left padding here — each link already gets 32px from `.train-toc a`, so
       adding more would push the nav 32px right of the TOC labels (misaligned). */
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }
  /* Match the TOC section links exactly (size/weight/colour come from .train-toc a);
     no extra dimming, so the nav reads as the same family, just lowercased. */
  .toc-nav-link {
    position: relative;
    text-decoration: none;
    text-transform: lowercase;
    transition: color 0.2s ease;
  }
  /* Darken to ink on hover, exactly like a TOC section link. Scoped under
     `.train-toc a` so it out-specifies the base `.train-toc a { color: muted }`
     rule (which includes the `a` element selector and would otherwise win). */
  .train-toc a.toc-nav-link:hover { color: var(--ink); }
  .toc-nav-link .nav-arrow { font-weight: 700; font-size: 1.35rem; line-height: 1; }
  /* Alignment (Rohan's 2026-07-13 call, superseding the hanging-arrow round):
     the arrows sit IN the text flow with a single space's worth of gap, and
     prev's ‹ starts at the same 32px column as the other links — so the LINK
     left edges are flush (the "prev" word itself sits right of the arrow,
     which is fine and intended). */
  .toc-nav-prev .nav-arrow { margin-right: 0.3rem; }
  .toc-nav-next .nav-arrow { margin-left: 0.3rem; }

  .stop-nav { display: flex; justify-content: space-between; align-items: center; gap: 1rem; margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid rgba(0,0,0,0.1); flex-wrap: wrap; }
  @media (min-width: 1000px) { .stop-nav { display: none; } }
  .stop-nav a { text-decoration: none; font-weight: 700; color: var(--line-projects); display: flex; flex-direction: column; gap: 0.15rem; }
  .stop-nav a span { color: var(--muted); font-weight: 500; font-size: 0.85rem; }
  .stop-nav .next { text-align: right; }
  .stop-nav .to-line { color: var(--ink); }
</style>

<style is:global>
  /* The PageLayout spine's station capsule sits right next to the banner and
     reads as a stray TOC tick on detail pages — the train-line TOC is the
     station marker here, so hide the spine's. */
  body.page-projects .station-here { display: none; }

  /* Detail pages uncap the page-body (it starts at x=0) so the article can be
     positioned in raw viewport coordinates — [slug].astro's --article-left —
     and be genuinely viewport-centred. Scoped via :has(.article-layout) so
     platform/list pages keep --max. */
  @media (min-width: 1000px) {
    .page-body:has(.article-layout) { max-width: none; }
  }

  /* Legacy classes carried over from the old site's markdown bodies. */
  /* Glossary terms: a soft projects-red HIGHLIGHT + solid underline (mirrors
     the original site's treatment — the dotted underline alone was too easy to
     miss). Ink text on the tint keeps it distinct from links, which are
     red TEXT. The highlight is the affordance, so no cursor:help. */
  .gloss-term {
    background: rgba(209, 61, 89, 0.1);
    border-bottom: 1px solid rgba(209, 61, 89, 0.55);
    border-radius: 3px;
    padding: 0.02em 0.12em;
  }
  .gloss-term:hover, .gloss-term:focus-visible { background: rgba(209, 61, 89, 0.2); outline: none; }
  /* Floating glossary tooltip (positioned by article.ts). */
  .gloss-tooltip {
    position: fixed;
    z-index: 3200;
    max-width: min(300px, 82vw);
    padding: 0.62rem 0.78rem;
    /* Warm cream card with ink text and a hairline in the section's red — matches
       the light theme (the original's light-theme tooltip), not a stark black box. */
    background: #fbf7ee;
    color: var(--ink);
    border: 1px solid rgba(209, 61, 89, 0.22);
    font-size: 0.85rem;
    font-weight: 500;
    line-height: 1.45;
    border-radius: 8px;
    box-shadow: 0 10px 28px rgba(62, 39, 35, 0.18);
    pointer-events: none;
    opacity: 0;
    transform: translateY(2px);
    transition: opacity 0.14s ease, transform 0.14s ease;
  }
  .gloss-tooltip.is-visible { opacity: 1; transform: translateY(0); }

  /* Zoomable image wrapper: sizes to the image and centres it (narrow images sit
     centred, not left-aligned), with a "click to expand" hint bottom-right. */
  .article-zoom {
    position: relative;
    display: block;
    width: fit-content;
    max-width: 100%;
    margin: 1.5rem auto;
    cursor: zoom-in;
  }
  .article-zoom img { margin: 0 !important; }
  /* Portrait / phone screenshots: kept narrow and centred, not stretched full-width. */
  .article-zoom.is-portrait { max-width: 360px; }
  .article-zoom::after {
    content: attr(data-hint);
    position: absolute;
    right: 0.7rem;
    bottom: 1rem;
    padding: 0.32rem 0.5rem;
    border: 1px solid rgba(26, 26, 26, 0.14);
    border-radius: 5px;
    background: rgba(251, 247, 238, 0.92);
    color: var(--muted-2);
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    pointer-events: none;
    opacity: 0.9;
    transition: opacity 0.18s ease, background 0.18s ease;
  }
  .article-zoom:hover::after { opacity: 1; background: #fff; }
  .try-it-btn, .support-btn {
    display: inline-block; text-decoration: none; font-weight: 700;
    padding: 0.5rem 1.1rem; border-radius: 999px; margin: 0.25rem 0.5rem 0.25rem 0;
    background: var(--line-projects); color: #fff;
  }
  .try-it-btn:hover { filter: brightness(1.12); }
  .support-btn { background: transparent; color: var(--line-projects); border: 2px solid var(--line-projects); }
  .support-btn:hover { background: var(--line-projects); color: #fff; }
  .download-actions, .bqst-download-actions { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; }
  .article-stat-grid { display: flex; flex-wrap: wrap; gap: 1rem; margin: 1.5rem 0; }
  .article-stat-card { flex: 1 1 160px; background: #fff; border-radius: var(--radius); padding: 1rem; box-shadow: 0 4px 16px rgba(0,0,0,0.06); text-align: center; }
  .article-stat-value { display: block; font-size: 1.8rem; font-weight: 800; color: var(--line-projects); }
  .article-stat-label { display: block; color: var(--muted); font-size: 0.85rem; }
  .article-figure { margin: 1.5rem 0; }
  .article-caption { color: var(--muted); font-size: 0.85rem; text-align: center; margin-top: 0.4rem; }
  .bqst-data-table { border-collapse: collapse; width: 100%; }

  /* BQST static asset strip: a clean 3-image row. */
  .bqst-asset-strip {
    display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1rem; margin: 1.5rem 0;
  }
  .bqst-asset-card {
    display: flex; flex-direction: column; align-items: center; gap: 0.6rem;
    background: #fff; border-radius: var(--radius); padding: 1.2rem 1rem;
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
  }
  .bqst-asset-card img { width: min(70%, 150px); aspect-ratio: 1; object-fit: contain; margin: 0; border-radius: 0; box-shadow: none; cursor: default; }
  .bqst-asset-card span { color: var(--muted); font-size: 0.8rem; font-weight: 600; letter-spacing: 0.04em; text-align: center; }
  @media (max-width: 560px) { .bqst-asset-strip { grid-template-columns: 1fr; } }

  /* ============ Interactive widget styling (light theme) ============ */
  :root {
    /* Widget/visual accent = the projects line red (not amber — amber is reserved
       for the map's stop-lighting; the article's plots, meters and highlighted
       values read in the section's own colour). */
    --w-accent: var(--line-projects);
    --w-accent-glow: rgba(209,61,89,0.4);
    /* Widget cards/canvases match the page background exactly so they blend
       into the page rather than reading as a separate card. */
    --w-card: #eae7de;
    --w-border: rgba(0,0,0,0.12);
    --w-ink: var(--ink);
    --w-muted: var(--muted-2);
  }

  /* Image lightbox */
  .image-lightbox {
    position: fixed; inset: 0; z-index: 3000; display: flex; align-items: center; justify-content: center;
    padding: clamp(1rem, 3vw, 2.5rem); background: rgba(5,5,10,0.9);
    opacity: 0; visibility: hidden; transition: opacity 0.18s ease, visibility 0.18s ease; cursor: zoom-out;
  }
  .image-lightbox.is-visible { opacity: 1; visibility: visible; }
  .image-lightbox-img { max-width: min(96vw, 1600px); max-height: 86vh; object-fit: contain; border-radius: 6px; box-shadow: 0 20px 80px rgba(0,0,0,0.55); }
  .image-lightbox-hint {
    position: fixed; left: 50%; bottom: 1.2rem; transform: translateX(-50%);
    width: min(100% - 2rem, 420px); padding: 0.58rem 0.78rem; border-radius: 8px;
    background: rgba(20,20,20,0.72); color: #eee; font-size: 0.84rem; font-weight: 600; text-align: center;
  }
  /* Reserve the scrollbar gutter so the overflow lock below doesn't reflow the
     page when the bar vanishes (progressive enhancement — browsers without
     scrollbar-gutter just keep the old, minor layout jump). */
  html { scrollbar-gutter: stable; }
  body.image-lightbox-open { overflow: hidden; }

  /* Shared lab / audio demo card frame */
  .bqst-lab, .bqst-audio-demo {
    box-sizing: border-box; max-width: 100%; margin: 1.6rem 0 2rem;
    border: 1px solid var(--w-border); border-radius: 12px;
    background: linear-gradient(135deg, rgba(209,61,89,0.06), transparent 42%), var(--w-card);
    overflow: hidden;
  }
  .bqst-lab-header, .bqst-audio-demo-header {
    display: flex; justify-content: space-between; gap: 1rem; align-items: baseline;
    padding: 0.9rem 1rem 0.75rem; border-bottom: 1px solid var(--w-border);
  }
  .bqst-lab-kicker { font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-weight: 700; color: var(--line-projects); font-size: 1rem; }
  .bqst-lab-meta { color: var(--w-muted); font-size: 0.82rem; }

  .bqst-interactive-row { display: grid; grid-template-columns: 176px minmax(0, 1fr); align-items: center; gap: 0.4rem; padding: 0.6rem 0.9rem 0 0.3rem; }
  .bqst-drive-control { display: flex; justify-content: center; position: relative; color: var(--w-muted); }
  .bqst-drive-module { display: grid; justify-items: center; gap: 0.55rem; }
  .bqst-knob-stage { width: 138px; height: 138px; position: relative; display: grid; place-items: center; cursor: grab; touch-action: none; outline: none; }
  .bqst-knob-stage.is-dragging { cursor: grabbing; }
  /* Keyboard focus ring only — .pointer-grab marks pointer-initiated focus (see
     article-widgets.ts: programmatic focus() inherits input modality, and the
     first-ever grab after page load counted as keyboard, flashing this ring). */
  .bqst-knob-stage:focus-visible:not(.pointer-grab) { outline: 2px solid var(--w-accent); outline-offset: 4px; border-radius: 50%; }
  .bqst-knob-ticks { position: absolute; inset: 0; pointer-events: none; }
  .bqst-knob-ticks::before {
    content: ''; position: absolute; left: 50%; top: 50%; width: 138px; height: 138px;
    border-radius: 999px; border: 1.2px solid rgba(0,0,0,0.28); transform: translate(-50%, -50%);
  }
  .bqst-knob-tick {
    --tick-angle: 0deg; position: absolute; left: 50%; top: 50%; width: 1.35px; height: 9px;
    border-radius: 999px; background: rgba(0,0,0,0.3); transform-origin: 50% 69px;
    transform: translate(-50%, -69px) rotate(var(--tick-angle));
  }
  .bqst-knob-tick.bqst-tick-major { width: 2.1px; height: 16px; background: rgba(0,0,0,0.5); }
  .bqst-mini-knob {
    --bqst-knob-angle: 0deg; width: 114px; height: 114px; border-radius: 999px;
    background: url('/assets/images/projects/bqst/knob-large-cream.webp') center / 128% no-repeat;
    position: relative;
    transform: rotate(var(--bqst-knob-angle)); transform-origin: center;
  }
  .bqst-mini-knob span { display: none; }
  .bqst-drive-control label { display: grid; justify-items: center; gap: 0.1rem; text-align: center; }
  .bqst-drive-control label span { color: var(--line-projects); font-weight: 700; line-height: 1; }
  .bqst-drive-control label strong { color: var(--w-ink); font-size: 1.12rem; font-weight: 700; line-height: 1; }
  .bqst-drive-control input[type="range"] { position: absolute; opacity: 0; pointer-events: none; width: 1px; height: 1px; }
  .bqst-visual-canvas { box-sizing: border-box; display: block; max-width: 100%; width: 100%; height: 340px; }
  .bqst-legend { display: flex; flex-wrap: wrap; gap: 0.7rem; padding: 0.6rem 1rem 0.95rem; color: var(--w-muted); font-size: 0.82rem; }
  .bqst-legend span { display: inline-flex; align-items: center; gap: 0.35rem; }
  .bqst-legend i { width: 0.75rem; height: 0.75rem; border-radius: 999px; display: inline-block; }
  @media (max-width: 620px) {
    .bqst-interactive-row { grid-template-columns: 1fr; }
    .bqst-visual-canvas { height: 300px; }
  }

  /* BQST audio A/B demo */
  .bqst-audio-demo-body { padding: 1rem; }
  .bqst-audio-main { display: grid; gap: 0.8rem; min-width: 0; }
  .bqst-audio-controls { display: flex; align-items: center; gap: 0.85rem; }
  .bqst-audio-play {
    width: 58px; height: 58px; border-radius: 999px; border: 2px solid var(--w-accent);
    background: transparent; color: var(--line-projects); cursor: pointer; display: inline-flex; align-items: center; justify-content: center;
    font-size: 1rem; font-weight: 700; transition: background 180ms ease, color 180ms ease, box-shadow 180ms ease; flex-shrink: 0;
  }
  .bqst-audio-play:hover { background: var(--w-accent); color: var(--ink); box-shadow: 0 0 22px var(--w-accent-glow); }
  .bqst-audio-play.playing { background: var(--w-accent); color: var(--ink); box-shadow: 0 0 24px var(--w-accent-glow); }
  .bqst-audio-toggle {
    display: inline-grid; grid-template-columns: repeat(2, minmax(0, 1fr)); width: min(100%, 280px);
    padding: 0.2rem; border: 1px solid var(--w-border); border-radius: 999px; background: rgba(0,0,0,0.03);
  }
  .bqst-audio-toggle button {
    min-height: 34px; border: 0; border-radius: 999px; background: transparent; color: var(--w-muted);
    font-weight: 700; font-size: 0.92rem; cursor: pointer; transition: background 160ms ease, color 160ms ease, box-shadow 160ms ease;
  }
  .bqst-audio-toggle button.is-active { background: var(--w-accent); color: var(--ink); box-shadow: 0 0 18px var(--w-accent-glow); }
  .bqst-audio-wave {
    position: relative; height: 68px; border: 1px solid var(--w-border); border-radius: 8px; overflow: hidden;
    background: linear-gradient(180deg, rgba(209,61,89,0.06), rgba(209,61,89,0.02));
  }
  .bqst-audio-wave canvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
  .bqst-audio-wave span { position: absolute; inset: 50% 0 auto; height: 1px; background: rgba(0,0,0,0.16); }
  /* Playhead progress: a full-width bar scaled from the left. article-widgets.ts
     writes `transform: scaleX(ratio)` per frame — compositor-only, where the old
     per-frame `width` writes forced a relayout of the wave row 60x/s. The 2px
     leading edge lives inside the scaled box so it thins slightly at low ratios;
     the bar is square-cornered, so nothing visibly distorts under scaleX. */
  .bqst-audio-wave i {
    position: absolute; top: 0; bottom: 0; left: 0; width: 100%; display: block; pointer-events: none;
    background: linear-gradient(90deg, rgba(209,61,89,0.22), rgba(209,61,89,0.05));
    border-right: 2px solid var(--w-accent);
    transform: scaleX(0); transform-origin: left; will-change: transform;
  }

  /* Live chord monitor piano */
  .lcm-demo { margin: 1.5rem 0 0.5rem; }
  .lcm-readout { height: 6.5rem; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; margin-bottom: 1.25rem; overflow: hidden; }
  .lcm-chord { font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-size: 2.6rem; font-weight: 800; color: #33b4e5; line-height: 1.1; white-space: nowrap; }
  .lcm-chord.lcm-empty { color: var(--w-muted); font-size: 1.4rem; font-weight: 500; }
  .lcm-notes { margin-top: 0.5rem; font-size: 1.05rem; letter-spacing: 0.04em; color: var(--w-ink); min-height: 1.4rem; white-space: nowrap; }
  .lcm-alts { margin-top: 0.35rem; font-size: 0.85rem; color: var(--w-muted); min-height: 1.1rem; max-width: 100%; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .lcm-piano { position: relative; display: flex; height: 160px; max-width: 560px; margin: 0 auto; user-select: none; touch-action: none; }
  .lcm-key { padding: 0; font: inherit; cursor: pointer; display: flex; align-items: flex-end; justify-content: center; }
  .lcm-key.white { background: #ECEAE3; border: 1px solid #b9b6ad; border-radius: 0 0 5px 5px; margin: 0 1px; }
  .lcm-key.black { position: absolute; top: 0; width: 2.1rem; height: 62%; transform: translateX(-50%); background: #20202e; border: 2px solid #14141f; border-top: none; border-radius: 0 0 4px 4px; z-index: 2; }
  .lcm-key.active { background: var(--w-accent); border-color: var(--w-accent); }
  .lcm-key.black.active { border-color: #14141f; }
  .lcm-key-label { font-size: 0.7rem; font-weight: 700; padding-bottom: 0.5rem; pointer-events: none; }
  .lcm-key.white .lcm-key-label { color: #6a6a72; }
  .lcm-key.black .lcm-key-label { color: #cfcfd8; padding-bottom: 0.35rem; }
  .lcm-key.active .lcm-key-label { color: #1a1a2e; }
  .lcm-hint { text-align: center; font-size: 0.85rem; color: var(--w-muted); margin-top: 1rem; }
  @media (max-width: 560px) { .lcm-piano { height: 132px; } .lcm-key.black { width: 1.6rem; } .lcm-chord { font-size: 2rem; } }

  /* Demo player (This Website) */
  .demo-player { display: flex; align-items: center; gap: 1rem; padding: 0.5rem 0; margin: 1rem 0 1.5rem; min-height: 120px; flex-wrap: wrap; }
  .demo-waveform-canvas { flex: 1 1 240px; min-width: 0; height: 56px; display: block; }
  .demo-meters { display: flex; gap: 0.8rem; align-items: flex-end; flex-shrink: 0; }
  .demo-meter-group { display: flex; flex-direction: column; align-items: center; gap: 0.15rem; }
  .demo-meter-label { font-size: 11px; font-weight: 600; letter-spacing: 0.06em; color: var(--w-muted); }
  .demo-vu-canvas { width: 190px; height: 130px; border-radius: 4px; display: block; }
  .demo-vec-canvas { width: 140px; height: 140px; border-radius: 50%; display: block; }

  /* Theme palette grid */
  .theme-palette { display: flex; flex-direction: column; gap: 1rem; margin: 1rem 0 1.5rem; }
  .palette-group { border: 1px solid var(--w-border); border-radius: 8px; overflow: hidden; background: var(--w-card); }
  .palette-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.5rem 0.75rem; color: var(--w-muted); border-bottom: 1px solid var(--w-border); }
  .palette-swatches { display: grid; grid-template-columns: repeat(6, minmax(0, 1fr)); gap: 0; }
  .palette-swatch { display: flex; flex-direction: column; min-width: 0; overflow: hidden; }
  .palette-swatch-color { aspect-ratio: 1; }
  .palette-swatch-label { font-size: 0.72rem; text-align: center; padding: 0.3rem 0; letter-spacing: 0.02em; color: var(--w-muted); }
  @media (max-width: 560px) { .palette-swatches { grid-template-columns: repeat(4, minmax(0,1fr)); } }

  /* ============ Quantlab visuals (qla/qlf) ============
     Ported from the original site's style.css, light branch only, remapped to
     this page's palette: cards on cream (--w-card), ink text, projects red for
     accents/warn states, series amber only inside the canvases, verified
     green kept from the original light theme. Fonts follow the site (Helvetica
     for display, system mono for figures). */
  .qla-visual {
    box-sizing: border-box; max-width: 100%; margin: 1.4rem 0 2rem;
    border: 1px solid var(--w-border); border-radius: 12px;
    background: linear-gradient(135deg, rgba(209,61,89,0.06), transparent 42%), var(--w-card);
    overflow: hidden;
  }
  .qla-visual-header {
    display: flex; justify-content: space-between; flex-wrap: wrap;
    gap: 0.35rem 1rem; padding: 0.9rem 1rem 0.75rem; border-bottom: 1px solid var(--w-border);
  }
  .qla-visual-kicker { font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-weight: 700; color: var(--line-projects); font-size: 1rem; }
  .qla-visual-meta { color: var(--w-muted); font-size: 0.82rem; }
  .qla-visual-body { padding: 1rem; }
  @media (max-width: 640px) { .qla-visual-body { padding: 0.8rem; } }

  .qla-btn {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-weight: 700; font-size: 0.88rem;
    padding: 0.45rem 1.1rem; border-radius: 999px; border: 1px solid var(--w-border);
    background: #f4f1ea; color: var(--w-ink); cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .qla-btn:hover { border-color: rgba(0,0,0,0.28); background: #fbf8f1; }
  .qla-btn:focus-visible { outline: 2px solid var(--w-accent); outline-offset: 2px; }
  .qla-btn-accent { background: var(--line-projects); color: #fff; border-color: transparent; }
  .qla-btn-accent:hover { background: var(--line-projects); border-color: transparent; filter: brightness(1.08); }
  @media (prefers-reduced-motion: reduce) { .qla-btn { transition: none; } }

  /* compounding curve + shared canvas bits */
  .qla-compound-takeaway { margin: 0.4rem 0 0.8rem; min-height: 2.9em; color: rgba(26,26,26,0.72); font-size: 0.92rem; font-style: italic; }
  .qla-compound-canvas { display: block; width: 100%; max-width: 100%; }
  .qla-compound-canvas-wrap { position: relative; }
  .qla-compound-canvas-wrap.qlf-cross-focus { outline: 2px solid var(--w-accent); outline-offset: 3px; border-radius: 4px; }

  /* gate exhibit: memo excerpts with marked numbers */
  .qla-memo {
    border: 1px solid var(--w-border); border-radius: 6px; background: #f4f1ea;
    padding: 0.9rem 1rem; white-space: pre-wrap; font-size: 0.85rem; line-height: 1.55; color: rgba(26,26,26,0.78);
  }
  .qla-mark-bad, .qla-mark-good { padding: 0 0.15em; border-radius: 3px; font-weight: 700; }
  .qla-mark-bad { background: rgba(209,61,89,0.14); color: #b52e49; }
  .qla-mark-good { background: rgba(102,187,106,0.14); color: #66bb6a; }
  .qla-gate-report-strip {
    display: flex; align-items: center; flex-wrap: wrap; gap: 0.45rem; margin: 0.2rem 0 0.8rem;
    padding: 0.5rem 0.7rem; border: 1px dashed var(--w-border); border-radius: 6px; background: #f4f1ea;
  }
  .qla-gate-report-label, .qla-gate-report-tail {
    color: var(--w-muted); font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;
  }
  .qla-gate-chip {
    font-family: 'SF Mono', 'JetBrains Mono', Menlo, monospace; font-size: 0.78rem; padding: 0.08em 0.45em;
    border-radius: 4px; background: rgba(209,61,89,0.12); color: #b52e49; border: 1px solid rgba(209,61,89,0.35);
  }
  .qla-gate-report-title {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-weight: 700; font-size: 0.85rem;
    color: var(--w-muted); display: flex; gap: 0.7rem; align-items: baseline; flex-wrap: wrap;
  }
  .qla-fixer-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 0.9rem; }
  .qla-fixer-col { min-width: 0; }
  .qla-fixer-col-title { font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-weight: 700; font-size: 0.82rem; color: var(--w-muted); margin-bottom: 0.4rem; }

  /* you be the judge */
  .qla-judge-status { font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-weight: 700; color: var(--w-muted); font-size: 0.85rem; margin: 0 0 0.7rem; }
  .qla-judge-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 0.9rem; margin-bottom: 0.9rem; }
  .qla-judge-col { display: flex; flex-direction: column; align-items: center; gap: 0.7rem; min-width: 0; }
  .qla-judge-col .qla-judge-panel { align-self: stretch; }
  .qla-judge-probe { visibility: hidden; }
  .qla-judge-panel { border: 1px solid var(--w-border); border-radius: 6px; background: #f4f1ea; overflow: hidden; }
  .qla-judge-panel.is-pick-correct { border-color: #66bb6a; box-shadow: 0 0 0 1px #66bb6a; }
  .qla-judge-panel.is-pick-wrong { border-color: var(--line-projects); box-shadow: 0 0 0 1px var(--line-projects); }
  .qla-judge-panel-label {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-weight: 700; font-size: 0.82rem;
    color: var(--line-projects); padding: 0.55rem 0.9rem; border-bottom: 1px solid var(--w-border);
  }
  .qla-judge-panel-body { padding: 0.8rem 0.9rem; white-space: pre-wrap; font-size: 0.83rem; line-height: 1.55; color: rgba(26,26,26,0.78); overflow: hidden; }
  .qla-judge-guess:disabled { opacity: 0.45; cursor: default; }
  .qla-judge-guess:disabled:hover { border-color: var(--w-border); background: #f4f1ea; }
  .qla-judge-controls { justify-content: center; min-height: 2.6em; display: flex; gap: 0.6rem; flex-wrap: wrap; margin-top: 0.2rem; }
  .qla-judge-feedback { min-height: 1.7em; line-height: 1.7; text-align: center; color: var(--w-ink); font-size: 0.92rem; font-weight: 700; margin: 0.3rem 0 0; }
  .qla-judge-feedback.is-correct { color: #66bb6a; }
  .qla-judge-feedback.is-wrong { color: #b52e49; }
  .qla-judge-score { margin: 0; min-height: 1.7em; line-height: 1.7; text-align: center; color: var(--w-ink); font-weight: 600; font-size: 0.9rem; }

  /* roster */
  .qla-roster-controls { display: flex; align-items: center; gap: 0.6rem; margin: 0.7rem 0 0.5rem; }
  .qla-roster-label { color: var(--w-muted); font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }
  .qla-roster-select {
    background: #f4f1ea; color: var(--w-ink); border: 1px solid var(--w-border); border-radius: 6px;
    padding: 0.35rem 0.6rem; font-family: inherit; font-size: 0.85rem; cursor: pointer;
  }
  .qla-roster-select:focus-visible { outline: 2px solid var(--w-accent); outline-offset: 1px; }
  .qla-roster-desc { margin: 0 0 0.4rem; min-height: 2.6em; color: rgba(26,26,26,0.72); font-size: 0.88rem; line-height: 1.3; }
  .qla-roster-stats { display: flex; flex-wrap: wrap; gap: 0.35rem 1.1rem; margin-bottom: 0.55rem; min-height: 1.4em; }
  .qla-roster-stat { color: var(--w-muted); font-family: 'SF Mono', 'JetBrains Mono', Menlo, monospace; font-size: 0.76rem; font-variant-numeric: tabular-nums; }
  .qla-roster-verdict { font-family: 'SF Mono', 'JetBrains Mono', Menlo, monospace; font-size: 0.76rem; font-weight: 700; color: #b52e49; }
  .qla-roster-verdict.is-pass { color: #66bb6a; }
  .qla-roster-memo { height: 300px; overflow-y: auto; margin-top: 0.5rem; scrollbar-width: thin; scrollbar-color: rgba(0,0,0,0.18) transparent; }
  .qla-roster-memo::-webkit-scrollbar { width: 6px; }
  .qla-roster-memo::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.18); border-radius: 3px; }

  /* legends + crosshair + readout (shared) */
  .qlf-legend { display: flex; justify-content: flex-end; gap: 0.3rem 1rem; flex-wrap: wrap; margin: 0.4rem 0 0.3rem; color: rgba(26,26,26,0.72); font-size: 0.78rem; }
  .qlf-legend-item { display: inline-flex; align-items: center; gap: 0.35rem; }
  .qlf-legend-swatch { display: inline-block; width: 9px; height: 9px; border-radius: 50%; background: currentColor; }
  .qlf-sw-series { color: var(--w-accent); } /* primary series: projects red */
  .qlf-sw-accent { color: #33b4e5; } /* second series in comparisons: blue */
  .qlf-sw-warn { color: var(--line-projects); }
  .qlf-sw-muted { color: var(--w-muted); }
  .qlf-legend-swatch.qla-sw-good { background: #66bb6a; }
  .qlf-legend-swatch.qla-sw-bad { background: var(--line-projects); }
  .qlf-legend-swatch.qlf-sw-gap { background: rgba(209,61,89,0.14); box-shadow: inset 0 0 0 1px rgba(209,61,89,0.45); }
  .qlf-legend-swatch.qlf-sw-window { background: rgba(26,26,26,0.08); box-shadow: inset 0 0 0 1px rgba(26,26,26,0.3); }
  .qlf-legend-swatch.qlf-sw-rung { width: 3px; height: 12px; border-radius: 1px; color: rgba(26,26,26,0.6); }
  .qlf-crosshair-canvas { touch-action: pan-y; cursor: crosshair; }
  .qlf-sr-range {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
  }
  .qlf-readout { display: flex; gap: 0.4rem 1.4rem; flex-wrap: wrap; margin: 0.5rem 0 0.6rem; padding-left: 44px; transition: opacity 0.15s ease; }
  .qlf-readout.is-idle { opacity: 0.45; }
  .qlf-readout-field { display: inline-flex; align-items: baseline; gap: 0.45rem; }
  .qlf-readout-label { color: var(--w-muted); font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }
  .qlf-readout-value {
    display: inline-block; color: var(--w-ink); font-family: 'SF Mono', 'JetBrains Mono', Menlo, monospace;
    font-size: 0.84rem; font-variant-numeric: tabular-nums; border-bottom: 1px solid var(--w-border);
    text-align: right; min-height: 1.3em;
  }

  /* lookahead stat row */
  .qlf-mode-toggle { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem; }
  .qlf-mode-btn.is-active { background: var(--line-projects); color: #fff; border-color: transparent; }
  .qlf-la-readout { display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 0.7rem; margin-bottom: 0.9rem; }
  .qlf-la-stat { display: grid; gap: 0.15rem; padding: 0.5rem 0.7rem; border: 1px solid var(--w-border); border-radius: 6px; }
  .qlf-la-stat-hold { opacity: 0.85; }
  .qlf-la-big {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-weight: 700; font-size: 1.7rem;
    line-height: 1.1; font-variant-numeric: tabular-nums; color: var(--w-ink);
  }
  .qlf-la-stat-cheat .qlf-la-big { color: var(--line-projects); }
  .qlf-la-stat-honest .qlf-la-big { color: #33b4e5; }
  .qlf-la-stat-label { color: rgba(26,26,26,0.72); font-size: 0.8rem; }
  .qlf-la-window-note { margin: 0.35rem 0 0.7rem; color: var(--w-muted); font-size: 0.78rem; }
  .qlf-chip-note { margin: 0.4rem 0 0; color: var(--w-muted); font-size: 0.78rem; }

  /* imatrix captions: shared grid cell, no layout shift on toggle */
  .qla-imx-captions { display: grid; margin-top: 0.4rem; }
  .qla-imx-captions p { grid-area: 1 / 1; margin: 0; color: rgba(26,26,26,0.72); font-size: 0.92rem; font-style: italic; }
  .qla-imx-captions p.is-off { visibility: hidden; }

  /* survivorship meter */
  .qlf-meter { margin-top: 1rem; padding-top: 0.9rem; border-top: 1px solid var(--w-border); }
  .qlf-meter-big {
    margin: 0.7rem 0 0.3rem; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-weight: 700;
    font-size: 1.25rem; color: var(--w-ink); font-variant-numeric: tabular-nums;
  }
  .qlf-meter-big.is-at-measured { color: var(--w-accent); }

  /* risk gate playground */

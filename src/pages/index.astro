---
const destination = '/transit';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content={`0;url=${destination}`} />
    <link rel="canonical" href={new URL(destination, Astro.site)} />
    <title>redirecting to transit — rohan.jk</title>
  </head>
  <body>
    <p>Redirecting to <a href={destination}>the transit site</a>…</p>
  </body>
</html>

---
// Faint continuation of the transit mesh behind inner-page content, so every
// page reads as another place on the same map the ride just crossed.
import { LINES, VIEWBOX } from '../data/system';
import { filletPath } from '../lib/fillet';

interface Props {
  /** The page's own line is drawn slightly stronger. */
  lineId: string;
}
const { lineId } = Astro.props;
---
<svg
  class="map-backdrop"
  viewBox={`0 0 ${VIEWBOX.w} ${VIEWBOX.h}`}
  preserveAspectRatio="xMidYMid slice"
  aria-hidden="true"
>
  {LINES.map((line) => (
    <path
      d={filletPath(line.points)}
      fill="none"
      stroke={line.hex}
      stroke-width={8}
      stroke-linejoin="round"
      opacity={line.id === lineId ? 0.14 : 0.07}
    />
  ))}
</svg>

<style>
  .map-backdrop {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
  }
</style>

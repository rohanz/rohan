---
import { NAV_LINES } from '../data/system';
import { SOCIALS } from '../data/socials';
import { defaultPathFor } from '../lib/theme-paths';
const dests = NAV_LINES.map((l) => ({
  id: l.id,
  hex: l.hex,
  name: l.nav.name,
  href: l.nav.href,
}));
const classicHref = defaultPathFor(Astro.url.pathname);
---
<nav id="station-board" class="station-board" aria-label="Destinations">
  <h2 class="board-title"><span class="board-icon" aria-hidden="true">i</span> Destinations</h2>
  <div class="board-body">
    <ul>
      <li>
        <a
          href="/transit"
          data-terminal
          data-line="map"
          data-astro-prefetch="hover"
          class="board-link"
          style="--line-hex:var(--ink-strong)"
        >
          <span class="swatch swatch-home" aria-hidden="true"></span>
          <span class="board-name">Home</span>
        </a>
      </li>
      {dests.map((d) => (
        <li>
          <a
            href={d.href}
            data-terminal
            data-line={d.id}
            data-astro-prefetch="hover"
            class="board-link"
            style={`--line-hex:${d.hex}`}
          >
            <span class="swatch" style={`background:${d.hex}`} aria-hidden="true"></span>
            <span class="board-name">{d.name}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
  <div class="board-classic">
    <a
      class="classic-site-link"
      href={classicHref}
      data-theme-pref="default"
      data-ride-ignore
    >Classic Site</a>
  </div>
  <div class="board-fasttravel">
    <button
      type="button"
      id="fast-travel"
      class="ft-switch"
      role="switch"
      aria-checked="false"
    >
      <span class="ft-label">Fast Travel</span>
      <span class="ft-track" aria-hidden="true"><span class="ft-knob"></span></span>
    </button>
  </div>
  <div class="board-social">
    {SOCIALS.map((s) => (
      <a
        class="social-link"
        href={s.href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={s.name}
        title={s.name}
      >
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d={s.icon} /></svg>
      </a>
    ))}
  </div>
</nav>

<style>
  /* Modeled on the CTA diagram's Legend panel: black header bar with the
     white "i" roundel, white body with dark rows. Now a persistent left nav
     rail (see MapApp.astro for placement) rather than a map-view-only
     panel, so it's slimmed down from its earlier map-centered sizing. */
  .station-board {
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.28);
    /* The container carries the white fill: .board-body alone left the
       fast-travel + socials rows transparent (map showed through). */
    background: #fff;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }
  .board-title {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin: 0;
    padding: 0.95rem 1.1rem;
    font-size: 1.35rem;
    font-weight: 700;
    color: #fff;
    background: var(--ink-strong);
  }
  .board-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.6rem;
    height: 1.6rem;
    border-radius: 50%;
    background: #fff;
    color: var(--ink-strong);
    font-weight: 700;
    font-size: 1.05rem;
    font-style: normal;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    line-height: 1;
    /* optical centering: Helvetica's lowercase "i" sits slightly left/high
       of its box metrics, so nudge it into the visual middle of the disc */
    padding-bottom: 0.05em;
  }
  .board-body { background: #fff; padding: 0.65rem 0.6rem 0.8rem; }
  .board-body ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; }
  .board-link {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.62rem 0.7rem;
    border-radius: 6px;
    text-decoration: none;
    color: var(--ink-strong);
    font-weight: 700;
    font-size: 1.45rem;
    transition: background 0.15s ease;
  }
  .board-link:hover, .board-link:focus-visible { background: rgba(0, 0, 0, 0.07); }
  /* Active row (the platform currently being ridden): a tint of the line's
     own color plus a bolder label, so the rail always reflects where you
     are — it persists on-screen through every view now. */
  .board-link.active {
    background: color-mix(in srgb, var(--line-hex) 14%, transparent);
  }
  .board-link.active .board-name { font-weight: 800; }
  /* Legend swatches are short line segments, not dots. Hover simply makes the
     bar LONGER (animating width, not scaleX) so it grows rightward with crisp
     rounded caps and no scale distortion. */
  .swatch { width: 40px; height: 11px; border-radius: 2px; flex: none; transition: width 0.15s ease; background: var(--line-hex); }
  .board-link:hover .swatch, .board-link:focus-visible .swatch { width: 56px; }
  /* Home's row gets a mini version of the map's Home interchange capsule
     (white circle, dark ring) instead of a line-color bar. */
  .swatch-home {
    width: 19px;
    height: 19px;
    border-radius: 50%;
    background: #fff;
    border: 3px solid var(--ink-strong);
    box-sizing: border-box;
  }
  /* Home's swatch is a fixed roundel — keep it at 19px on hover (the base
     .swatch hover rule would otherwise stretch it). */
  .board-link:hover .swatch-home, .board-link:focus-visible .swatch-home { width: 19px; }

  /* Bidirectional hover sync: when a MAP line is hovered, #map-3d[data-hl]
     is set, and the matching rail row should show the SAME visual it gets on
     :hover (background tint + lengthened swatch). The rail (#station-board)
     is NOT a descendant of #map-3d — both live under #tt-main — so we key off a
     :has() on the common #tt-main ancestor rather than a descendant selector.
     (This also fires when hovering the rail row itself, since ride.ts sets
     data-hl from that source too — harmless, it just matches the :hover state.) */
  :global(#tt-main:has(#map-3d[data-hl='music'])) .board-link[data-line='music'],
  :global(#tt-main:has(#map-3d[data-hl='projects'])) .board-link[data-line='projects'],
  :global(#tt-main:has(#map-3d[data-hl='about'])) .board-link[data-line='about'] {
    background: rgba(0, 0, 0, 0.07);
  }
  :global(#tt-main:has(#map-3d[data-hl='music'])) .board-link[data-line='music'] .swatch,
  :global(#tt-main:has(#map-3d[data-hl='projects'])) .board-link[data-line='projects'] .swatch,
  :global(#tt-main:has(#map-3d[data-hl='about'])) .board-link[data-line='about'] .swatch {
    width: 56px;
  }

  /* Fast Travel switch — secondary chrome, so it reads smaller than the
     destination rows above. Sits just above the socials, sharing the same
     hairline divider language. A signage-style pill track + sliding knob;
     flat by house rule (no box-shadow on the knob). ON tints the track amber
     (the stop-light #f9c25e) so it reads as a lit signal against the ink rail. */
  .board-fasttravel {
    padding: 0.15rem 0.7rem 0.15rem;
  }
  .board-classic {
    padding: 0.55rem 0.7rem 0.15rem;
  }
  .classic-site-link {
    display: flex;
    align-items: center;
    width: 100%;
    padding: 0.4rem 0.7rem;
    border-radius: 6px;
    color: var(--ink-strong);
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-weight: 700;
    font-size: 1.2rem;
    letter-spacing: 0.01em;
    line-height: normal;
    text-decoration: none;
    transition: background 0.15s ease;
  }
  .classic-site-link:hover, .classic-site-link:focus-visible { background: rgba(0, 0, 0, 0.07); }
  .ft-switch {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    width: 100%;
    padding: 0.4rem 0.7rem;
    border: 0;
    border-radius: 6px;
    background: transparent;
    color: var(--ink-strong);
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-weight: 700;
    font-size: 1.2rem;
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .ft-switch:hover, .ft-switch:focus-visible { background: rgba(0, 0, 0, 0.07); }
  .ft-label { letter-spacing: 0.01em; }
  .ft-track {
    position: relative;
    flex: none;
    width: 52px;
    height: 26px;
    border-radius: 999px;
    /* Solid grey fill, borderless (Rohan: more minimal) — the fill alone
       separates the pill from the white board; a white track would vanish. */
    background: #d7d2c8;
    transition: background 0.15s ease;
  }
  .ft-knob {
    position: absolute;
    top: 50%;
    left: 4px;
    width: 17px;
    height: 17px;
    border-radius: 50%;
    background: var(--ink-strong);
    transform: translate(0, -50%);
    transition: transform 0.18s cubic-bezier(0.4, 0, 0.2, 1), background 0.15s ease;
  }
  /* ON = the train-line light blue (the site's speed/motion accent), white
     knob for contrast. Amber is reserved for the stop-lighting language. */
  .ft-switch[aria-checked='true'] .ft-track {
    background: #33b4e5;
  }
  .ft-switch[aria-checked='true'] .ft-knob {
    background: #fff;
    /* 52 track − 17 knob − 4px rest gap each side = 27 (integer → crisp). */
    transform: translate(27px, -50%);
  }

  /* External socials, pinned to the bottom of the rail (the .board-body above
     flexes to fill, pushing this row down). Muted monochrome icons that darken
     to ink on hover — distinct from the destination rows, not another line. */
  .board-social {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.05rem 1.35rem;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }
  .social-link {
    display: inline-flex;
    color: #8a8578;
    transition: color 0.18s ease, transform 0.18s ease;
  }
  .social-link:hover, .social-link:focus-visible { color: var(--ink-strong); transform: translateY(-2px); }
  .social-link svg { display: block; width: 29px; height: 29px; fill: currentColor; }
  @media (max-width: 1024px) {
    .board-social { padding: 0.9rem 1rem; }
    .social-link svg { width: 22px; height: 22px; }
  }
</style>

<script>
  import { FAST_TRAVEL_KEY } from '../scripts/ride/keys';

  // Fast Travel toggle. Persisted in sessionStorage under the shared namespaced key ('1' = on):
  // it survives page navigations within a visit but every NEW visit starts OFF
  // (owner's call — off by default, always). The rail renders on EVERY page (map +
  // detail article pages), so this binds on each astro:page-load against the
  // freshly-swapped DOM and reflects the stored state. When ON, the ride engine
  // (ride.ts) lets rail clicks fall through to a real ClientRouter navigation, so
  // the existing thin streak wipe runs instead of the camera train ride — see the
  // fastTravel() gate there (it MUST read the same key from the same storage).
  // Detail-page rails are already real navs; the toggle just renders + persists.
  function stored(): boolean {
    try {
      return sessionStorage.getItem(FAST_TRAVEL_KEY) === '1';
    } catch {
      return false;
    }
  }
  function bindFastTravel() {
    const btn = document.getElementById('fast-travel');
    if (!btn || btn.dataset.bound === '1') return;
    btn.dataset.bound = '1';
    const reflect = () => btn.setAttribute('aria-checked', stored() ? 'true' : 'false');
    reflect();
    // Native <button role="switch"> handles Space/Enter → click for us, so a
    // single click listener covers pointer + keyboard activation.
    btn.addEventListener('click', () => {
      const next = !stored();
      try {
        sessionStorage.setItem(FAST_TRAVEL_KEY, next ? '1' : '0');
      } catch {
        /* storage unavailable — the aria state below still reflects intent */
      }
      btn.setAttribute('aria-checked', next ? 'true' : 'false');
    });
  }
  document.addEventListener('astro:page-load', bindFastTravel);
  // astro:page-load doesn't fire on the very first load in some setups; cover it.
  if (document.readyState !== 'loading') bindFastTravel();
  else document.addEventListener('DOMContentLoaded', bindFastTravel);
</script>

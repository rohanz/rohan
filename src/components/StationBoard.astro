---
import { NAV_LINES } from '../data/system';
import { SOCIALS } from '../data/socials';
const dests = NAV_LINES.map((l) => ({
  id: l.id,
  hex: l.hex,
  name: l.nav.name,
  href: l.nav.href,
}));
---
<nav id="station-board" class="station-board" aria-label="Destinations">
  <h2 class="board-title"><span class="board-icon" aria-hidden="true">i</span> Destinations</h2>
  <div class="board-body">
    <ul>
      <li>
        <a
          href="/"
          data-terminal
          data-line="map"
          data-astro-prefetch="hover"
          class="board-link"
          style="--line-hex:var(--ink-strong)"
        >
          <span class="swatch swatch-home" aria-hidden="true"></span>
          <span class="board-name">Home</span>
        </a>
      </li>
      {dests.map((d) => (
        <li>
          <a
            href={d.href}
            data-terminal
            data-line={d.id}
            data-astro-prefetch="hover"
            class="board-link"
            style={`--line-hex:${d.hex}`}
          >
            <span class="swatch" style={`background:${d.hex}`} aria-hidden="true"></span>
            <span class="board-name">{d.name}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
  <div class="board-social">
    {SOCIALS.map((s) => (
      <a
        class="social-link"
        href={s.href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={s.name}
        title={s.name}
      >
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d={s.icon} /></svg>
      </a>
    ))}
  </div>
</nav>

<style>
  /* Modeled on the CTA diagram's Legend panel: black header bar with the
     white "i" roundel, white body with dark rows. Now a persistent left nav
     rail (see MapApp.astro for placement) rather than a map-view-only
     panel, so it's slimmed down from its earlier map-centered sizing. */
  .station-board {
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.28);
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }
  .board-title {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin: 0;
    padding: 0.95rem 1.1rem;
    font-size: 1.35rem;
    font-weight: 700;
    color: #fff;
    background: var(--ink-strong);
  }
  .board-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.6rem;
    height: 1.6rem;
    border-radius: 50%;
    background: #fff;
    color: var(--ink-strong);
    font-weight: 700;
    font-size: 1.05rem;
    font-style: normal;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    line-height: 1;
    /* optical centering: Helvetica's lowercase "i" sits slightly left/high
       of its box metrics, so nudge it into the visual middle of the disc */
    padding-bottom: 0.05em;
  }
  .board-body { background: #fff; padding: 0.65rem 0.6rem 0.8rem; }
  .board-body ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; }
  .board-link {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.62rem 0.7rem;
    border-radius: 6px;
    text-decoration: none;
    color: var(--ink-strong);
    font-weight: 700;
    font-size: 1.45rem;
    transition: background 0.15s ease;
  }
  .board-link:hover, .board-link:focus-visible { background: rgba(0, 0, 0, 0.07); }
  /* Active row (the platform currently being ridden): a tint of the line's
     own color plus a bolder label, so the rail always reflects where you
     are — it persists on-screen through every view now. */
  .board-link.active {
    background: color-mix(in srgb, var(--line-hex) 14%, transparent);
  }
  .board-link.active .board-name { font-weight: 800; }
  /* Legend swatches are short line segments, not dots. Hover simply makes the
     bar LONGER (animating width, not scaleX) so it grows rightward with crisp
     rounded caps and no scale distortion. */
  .swatch { width: 40px; height: 11px; border-radius: 2px; flex: none; transition: width 0.15s ease; background: var(--line-hex); }
  .board-link:hover .swatch, .board-link:focus-visible .swatch { width: 56px; }
  /* Home's row gets a mini version of the map's Home interchange capsule
     (white circle, dark ring) instead of a line-color bar. */
  .swatch-home {
    width: 19px;
    height: 19px;
    border-radius: 50%;
    background: #fff;
    border: 3px solid var(--ink-strong);
    box-sizing: border-box;
  }
  /* Home's swatch is a fixed roundel — keep it at 19px on hover (the base
     .swatch hover rule would otherwise stretch it). */
  .board-link:hover .swatch-home, .board-link:focus-visible .swatch-home { width: 19px; }

  /* Bidirectional hover sync: when a MAP line is hovered, #map-3d[data-hl]
     is set, and the matching rail row should show the SAME visual it gets on
     :hover (background tint + lengthened swatch). The rail (#station-board)
     is NOT a descendant of #map-3d — both live under #main — so we key off a
     :has() on the common #main ancestor rather than a descendant selector.
     (This also fires when hovering the rail row itself, since ride.ts sets
     data-hl from that source too — harmless, it just matches the :hover state.) */
  :global(#main:has(#map-3d[data-hl='music'])) .board-link[data-line='music'],
  :global(#main:has(#map-3d[data-hl='projects'])) .board-link[data-line='projects'],
  :global(#main:has(#map-3d[data-hl='about'])) .board-link[data-line='about'] {
    background: rgba(0, 0, 0, 0.07);
  }
  :global(#main:has(#map-3d[data-hl='music'])) .board-link[data-line='music'] .swatch,
  :global(#main:has(#map-3d[data-hl='projects'])) .board-link[data-line='projects'] .swatch,
  :global(#main:has(#map-3d[data-hl='about'])) .board-link[data-line='about'] .swatch {
    width: 56px;
  }

  /* External socials, pinned to the bottom of the rail (the .board-body above
     flexes to fill, pushing this row down). Muted monochrome icons that darken
     to ink on hover — distinct from the destination rows, not another line. */
  .board-social {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.05rem 1.35rem;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }
  .social-link {
    display: inline-flex;
    color: #8a8578;
    transition: color 0.18s ease, transform 0.18s ease;
  }
  .social-link:hover, .social-link:focus-visible { color: var(--ink-strong); transform: translateY(-2px); }
  .social-link svg { display: block; width: 29px; height: 29px; fill: currentColor; }
  @media (max-width: 1024px) {
    .board-social { padding: 0.9rem 1rem; }
    .social-link svg { width: 22px; height: 22px; }
  }
</style>

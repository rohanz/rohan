---
import { LINES, HOME, VIEWBOX, type Point } from '../data/system';

function polyPoints(pts: Point[]) {
  return pts.map(([x, y]) => `${x},${y}`).join(' ');
}

---
<div class="map-tilt">
  <svg
    id="transit-map"
    class="transit-map"
    viewBox={`0 0 ${VIEWBOX.w} ${VIEWBOX.h}`}
    preserveAspectRatio="xMidYMid slice"
    aria-hidden="true"
  >
    <g data-camera>
      {LINES.map((line) => (
        <g data-line={line.id} class:list={['line-group', { nav: !!line.nav }]}>
          <!-- casing: background-colored under-stroke separates crossings, CTA-print style -->
          <polyline
            class="line-casing"
            points={polyPoints(line.points)}
            fill="none"
            stroke="var(--bg)"
            stroke-width={line.nav ? 14 : 12}
            stroke-linecap="butt"
            stroke-linejoin="round"
          />
          <polyline
            class="line-path"
            points={polyPoints(line.points)}
            fill="none"
            stroke={line.hex}
            stroke-width={line.nav ? 9 : 7}
            stroke-linecap="butt"
            stroke-linejoin="round"
          />
          {line.ticks.map((t) => (
            <circle cx={t[0]} cy={t[1]} r={line.nav ? 5.5 : 5} fill="#fff" stroke="var(--ink)" stroke-width="2.4" />
          ))}
          {line.nav && (
            <polyline
              class="hit-path"
              data-ride-line={line.id}
              data-href={line.nav.href}
              points={polyPoints(line.points)}
              fill="none"
              stroke="transparent"
              stroke-width="26"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          )}
        </g>
      ))}

      <!-- HOME — the only named station; CTA transfer-station capsule -->
      <g class="home">
        <circle cx={HOME[0]} cy={HOME[1]} r="15" fill="#fff" stroke="var(--ink)" stroke-width="5" />
        <text x={HOME[0] - 24} y={HOME[1] - 22} class="home-label" fill="var(--ink)" text-anchor="end">HOME</text>
        <text x={HOME[0] - 24} y={HOME[1] - 8} class="home-sub" fill="var(--muted)" text-anchor="end">you are here</text>
      </g>
    </g>
    <g id="streaks" aria-hidden="true"></g>
    <defs>
      <filter id="motion-blur" x="-40%" y="-40%" width="180%" height="180%">
        <feGaussianBlur id="motion-blur-gauss" stdDeviation="0 0" />
      </filter>
    </defs>
  </svg>
</div>

<style>
  .map-tilt { width: 100%; height: 100%; perspective: 1200px; }
  .transit-map { width: 100%; height: 100%; display: block; transform-style: preserve-3d; }
  .home-label { font-size: 18px; font-weight: 800; letter-spacing: 0.04em; }
  .home-sub { font-size: 11px; font-weight: 500; letter-spacing: 0.06em; }
  .hit-path { cursor: pointer; pointer-events: stroke; }
  /* During a ride only the HOME text gets out of the way; other lines stay crisp
     (the whole camera carries speed-proportional motion blur instead). */
  #transit-map.ride-active .home text { opacity: 0; transition: opacity 0.25s ease; }
</style>

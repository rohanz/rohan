---
import { LINES, NAV_LINES, HOME, VIEWBOX, type Point } from '../data/system';
import { filletPath } from '../lib/fillet';

function polyPoints(pts: Point[]) {
  return pts.map(([x, y]) => `${x},${y}`).join(' ');
}

// Land-use zones, CTA-diagram style: tan land, lighter city core, pale parks,
// light-blue river + lake. World coordinates (move with the camera).
const LAND = '#e4e1d8';
const CITY = '#eeebe4';
const PARK = '#dde9d7';
const WATER = '#d0e4ee';
const PARKS: [number, number, number, number][] = [
  [40, 30, 130, 170],
  [520, 470, 150, 100],
  [700, -60, 150, 100],
  [-160, 180, 170, 110],
  // along the music corridor
  [480, -480, 180, 120],
  [460, -160, 140, 100],
  [760, -620, 150, 100],
  [140, -700, 160, 110],
  // along the projects corridor
  [540, 950, 170, 130],
  [700, 1150, 160, 110],
  [480, 700, 150, 100],
  // along the about corridor
  [-460, 610, 170, 100],
  [-700, 850, 180, 120],
  [-1000, 620, 150, 90],
  // wider world
  [-800, 300, 200, 140],
  [-900, -300, 180, 120],
  [-100, 1000, 220, 150],
  [300, 1500, 200, 130],
  [-1200, 700, 180, 110],
  [200, -1000, 180, 120],
];
const RIVER: Point[] = [
  [240, -1600],
  [240, -140],
  [360, -20],
  [360, 520],
  [240, 640],
  [240, 2000],
];
// Lake shoreline (east edge), gentle octilinear steps.
const LAKE = 'M880,-1600 L2600,-1600 L2600,2000 L880,2000 L880,1160 L930,1110 L930,330 L880,280 Z';
---
<div class="map-tilt">
  <div class="map-3d" id="map-3d">
  <!-- Depth layer 1 (farthest): land, parks, river, lake -->
  <svg
    class="layer layer-land"
    viewBox={`0 0 ${VIEWBOX.w} ${VIEWBOX.h}`}
    preserveAspectRatio="xMidYMid slice"
    aria-hidden="true"
  >
    <g data-camera-land>
      <rect x="-1600" y="-1600" width="4200" height="3600" fill={LAND} />
      <g data-land-zones>
        <rect x="150" y="90" width="700" height="580" rx="26" fill={CITY} />
        {PARKS.map(([x, y, w, h]) => (
          <rect x={x} y={y} width={w} height={h} rx="12" fill={PARK} />
        ))}
      </g>
      <!-- faint graph grid: map-paper feel; water covers it -->
      <rect x="-1600" y="-1600" width="4200" height="3600" fill="url(#grid)" opacity="0.05" />
      <g data-land-water>
        <polyline points={polyPoints(RIVER)} fill="none" stroke={WATER} stroke-width="24" stroke-linejoin="round" />
        <path d={LAKE} fill={WATER} />
      </g>
    </g>
    <defs>
      <pattern id="grid" width="50" height="50" patternUnits="userSpaceOnUse">
        <path d="M50,0 H0 V50" fill="none" stroke="var(--ink)" stroke-width="1" />
      </pattern>
    </defs>
  </svg>

  <!-- Depth layer 2: the lines themselves (also the click surface) -->
  <svg
    id="transit-map"
    class="layer transit-map"
    viewBox={`0 0 ${VIEWBOX.w} ${VIEWBOX.h}`}
    preserveAspectRatio="xMidYMid slice"
    aria-hidden="true"
  >
    <g data-camera>
      <g id="lines-world">
      {LINES.map((line) => (
        <g data-line={line.id} class:list={['line-group', { nav: !!line.nav }]} style={`--glow:${line.hex}`}>
          <path
            class="line-path"
            d={filletPath(line.points)}
            fill="none"
            stroke={line.hex}
            stroke-width={line.nav ? 9 : 7}
            stroke-linecap="round"
            stroke-linejoin="round"
          />
          {line.nav && (
            <path
              class="hit-path"
              data-ride-line={line.id}
              data-href={line.nav.href}
              d={filletPath(line.points)}
              fill="none"
              stroke="transparent"
              stroke-width="26"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          )}
        </g>
      ))}

      <!-- All stops drawn AFTER every line: a stop on an intersection can
           never hide behind another line. Grouped per line so a parked view
           can fade the others; platform stops are the content anchors. -->
      <g class="stops">
        {LINES.map((line) => (
          <g data-ticks-for={line.id}>
            {line.ticks.map((t) => <circle data-at={`${t[0]},${t[1]}`} cx={t[0]} cy={t[1]} r="5" fill="#fff" stroke="var(--ink)" stroke-width="2.4" />)}
            {(line.terminals ?? []).map((t) => <circle cx={t[0]} cy={t[1]} r="9" fill="#fff" stroke="var(--ink)" stroke-width="3.5" />)}
          </g>
        ))}
        {NAV_LINES.map((line) => (
          <g data-pstops={line.id}>
            {(line.platform?.stops ?? []).map((t) => (
              <circle data-at={`${t[0]},${t[1]}`} cx={t[0]} cy={t[1]} r="6.5" fill="#fff" stroke="var(--ink)" stroke-width="2.8" />
            ))}
          </g>
        ))}
      </g>
      </g>
    </g>
    <!-- Motion blur as filter-free echo taps: two unfiltered copies of the
         lines, offset along the travel direction at low opacity. Pure
         transforms — no gaussian rasterization, so no frame spikes ever. -->
    <g data-echo="1" opacity="0" pointer-events="none" aria-hidden="true">
      <use href="#lines-world" />
    </g>
    <g data-echo="2" opacity="0" pointer-events="none" aria-hidden="true">
      <use href="#lines-world" />
    </g>
  </svg>

  <!-- Depth layer 3 (nearest): stations that float above the lines -->
  <svg
    class="layer layer-top"
    viewBox={`0 0 ${VIEWBOX.w} ${VIEWBOX.h}`}
    preserveAspectRatio="xMidYMid slice"
    aria-hidden="true"
  >
    <g data-top-camera>
      <!-- Destination stations at the far end of each ride (off-canvas at rest;
           the camera brakes into them at the end of a ride) -->
      {NAV_LINES.map((line) => {
        const end = line.ride[line.ride.length - 1];
        return (
          <g class="destination" data-destination={line.id}>
            <circle cx={end[0]} cy={end[1]} r="15" fill="#fff" stroke="var(--ink)" stroke-width="5" />
          </g>
        );
      })}

      <!-- HOME — the only named station -->
      <g class="home">
        <circle id="home-dot" cx={HOME[0]} cy={HOME[1]} r="15" fill="#fff" stroke="var(--ink)" stroke-width="5" />
        <text x={HOME[0] - 24} y={HOME[1] - 22} class="home-label" style="font-family:'Helvetica Neue',Helvetica,Arial,sans-serif" fill="var(--ink)" text-anchor="end">Home</text>
        <text x={HOME[0] - 24} y={HOME[1] - 8} class="home-sub" style="font-family:'Helvetica Neue',Helvetica,Arial,sans-serif" fill="var(--muted)" text-anchor="end">You are here</text>
      </g>
    </g>
  </svg>
  </div>
</div>

<style>
  .map-tilt { width: 100%; height: 100%; }
  .map-3d { position: relative; width: 100%; height: 100%; }
  .layer { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
  .layer-top { pointer-events: none; }
  .home-label { font-size: 18px; font-weight: 700; letter-spacing: 0.04em; }
  .home-sub { font-size: 11px; font-weight: 500; letter-spacing: 0.06em; }
  .hit-path { cursor: pointer; pointer-events: stroke; }
  #map-3d.ride-active .home text { opacity: 0; transition: opacity 0.25s ease; }
  /* Hover highlight: the hovered destination's line glows, the rest recede.
     Transitions are disabled during rides — animating filter/opacity forces
     re-rasterization every frame and reads as flicker. */
  .line-path { transition: opacity 0.25s ease, filter 0.25s ease; }
  :global(#map-3d.ride-active) .line-path { transition: none; filter: none; }
  :global(#map-3d[data-hl]:not(.ride-active)) .line-group .line-path { opacity: 0.55; }
  :global(#map-3d[data-hl='music']:not(.ride-active)) [data-line='music'] .line-path,
  :global(#map-3d[data-hl='projects']:not(.ride-active)) [data-line='projects'] .line-path,
  :global(#map-3d[data-hl='about']:not(.ride-active)) [data-line='about'] .line-path {
    opacity: 1;
    filter: drop-shadow(0 0 1.2px var(--glow));
  }
</style>

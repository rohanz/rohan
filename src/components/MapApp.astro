---
import Layout from '../layouts/Layout.astro';
import TransitMap from '../components/TransitMap.astro';
import StationBoard from '../components/StationBoard.astro';
import { getCollection } from 'astro:content';
import music from '../data/music.json';

interface Props {
  title: string;
  description: string;
  initialView?: 'music' | 'projects' | 'about';
}
const { title, description, initialView } = Astro.props;

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);

// Filter pills: one per unique technology across all projects, matching the
// full tag set from the original site (wraps to two centered rows if needed).
const filterTags = Array.from(new Set(projects.flatMap((p) => p.data.technologies))).sort();

const stats = [
  { value: '1.3m+', label: 'streams' },
  { value: '8+', label: 'projects built' },
];

const tech = [
  'Python',
  'JavaScript',
  'React',
  'C++',
  'JUCE',
  'DSP',
  'OpenAI',
  'Codex',
  'Google Cloud',
  'Node.js',
  'Docker',
  'Git',
  'Linux',
  'DuckDB',
  'PostgreSQL',
  'Claude',
  'Gemini',
];

const socials: [string, string][] = [
  ['github', 'https://github.com/rohanz'],
  ['spotify', 'https://open.spotify.com/artist/3I1V2FxqX2qs3zrUY0fCPp'],
  ['instagram', 'https://www.instagram.com/rrohan.jk/'],
  ['linkedin', 'https://www.linkedin.com/in/rohan-jk'],
];
---
<Layout title={title} description={description} bodyClass="home" initialView={initialView}>
  <header class="top-bar" id="logo-bar">
    <a id="logo" class="logo" href="/" aria-label="rohan.jk — home">
      <img src="/logo.svg" width="34" height="34" alt="" />
      <span class="logo-name">rohan.jk</span>
      <span class="logo-sub">system map</span>
    </a>
    <span id="bar-section" class="bar-section"></span>
  </header>

  <main id="main" class="map-stage">
    <div class="map-wrap"><TransitMap /></div>
    <StationBoard />

    <div id="platform-ui" hidden>
      <button id="more-prev" class="edge-btn edge-btn-left" type="button" hidden>← Back</button>
      <button id="more-next" class="edge-btn edge-btn-right" type="button" hidden>More projects →</button>
      <div id="filter-bar" hidden>
        <button type="button" class="filter-tag active" data-filter="all" aria-pressed="true">all</button>
        {filterTags.map((t) => (
          <button type="button" class="filter-tag" data-filter={t} aria-pressed="false">{t}</button>
        ))}
      </div>

      <div data-content="music" hidden>
        {Array.from({ length: music.length + 1 }).map(() => (
          <div class="platform-divider" data-divider="music" aria-hidden="true"></div>
        ))}
        {music.map((t) => (
          <div class="platform-row" data-card="music" data-audio-url={t.audio}>
            <div class="row-header">
              <img class="row-cover" src={t.cover} alt="" loading="lazy" />
              <div class="row-info">
                <h3 class="row-title">{t.title}</h3>
                <p class="row-artist">{t.artist}</p>
                <div class="row-links">
                  <a href={t.spotifyUrl} target="_blank" rel="noopener noreferrer">spotify</a>
                  <a href={t.appleMusicUrl} target="_blank" rel="noopener noreferrer">apple music</a>
                  <a href={t.youtubeUrl} target="_blank" rel="noopener noreferrer">youtube</a>
                </div>
              </div>
            </div>
            <!-- Order matches the original's waveform-player: play button,
                 then waveform, then meters (see main.js displayMusic). -->
            <button type="button" class="row-play" data-play aria-label="Play snippet" aria-pressed="false">
              <svg class="row-play-icon icon-play" viewBox="0 0 24 24" aria-hidden="true"><path d="M7 5.5v13l11-6.5z" /></svg>
              <svg class="row-play-icon icon-pause" viewBox="0 0 24 24" aria-hidden="true"><path d="M6.5 5h4v14h-4zM13.5 5h4v14h-4z" /></svg>
            </button>
            <canvas class="row-wave" height="56" aria-hidden="true"></canvas>
            <div class="row-meters">
              <div class="meter-group meter-group-freq">
                <canvas class="row-freq" width="282" height="110"></canvas>
                <span class="meter-label">freq</span>
              </div>
              <div class="meter-group">
                <canvas class="row-vec" width="110" height="110"></canvas>
                <span class="meter-label">stereo</span>
              </div>
              <div class="meter-group">
                <canvas class="row-vu" width="141" height="100"></canvas>
                <span class="meter-label">vu</span>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div data-content="projects" hidden>
        {projects.map((p) => (
          <a
            class="platform-card card-project"
            data-card="projects"
            data-tech={p.data.technologies.join('|')}
            href={`/projects/${p.id}`}
            data-astro-prefetch="hover"
          >
            <div class="card-inner">
              <img class="thumb" src={p.data.image} alt="" loading="lazy" />
              <div class="body">
                <h3>{p.data.title}</h3>
                <p class="summary">{p.data.summary}</p>
                <ul class="tags">
                  {p.data.technologies.map((t) => <li>{t}</li>)}
                </ul>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div data-content="about" hidden>
        <div class="platform-card card-about card-about-bio" data-card="about">
          <img class="photo" src="/assets/images/profile.webp" alt="" loading="lazy" />
          <p class="bio">hi, i'm rohan, a computer engineering student at ntu, singapore. i build end-to-end products with AI, from data pipelines and cloud infrastructure to mobile apps and everything in between. outside of code, i write, produce and record music. feel free to reach out below!</p>
        </div>

        <div class="platform-card card-about card-about-stats" data-card="about">
          <h3 class="about-label">Stats</h3>
          <div class="stat-row">
            {stats.map((s) => (
              <div class="stat-tile">
                <span class="stat-value">{s.value}</span>
                <span class="stat-label">{s.label}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="platform-card card-about card-about-tech" data-card="about">
          <h3 class="about-label">Tech stack</h3>
          <ul class="chips">
            {tech.map((name) => (
              <li class="chip">{name}</li>
            ))}
          </ul>
        </div>

        <div class="platform-card card-about card-about-socials" data-card="about">
          <h3 class="about-label">Socials</h3>
          <div class="social-buttons">
            {socials.map(([name, href]) => (
              <a class="social-btn" href={href} target="_blank" rel="noopener noreferrer">{name}</a>
            ))}
          </div>
        </div>

        <div class="platform-card card-about card-about-cv" data-card="about">
          <h3 class="about-label">CV</h3>
          <a class="cv-btn" href="/downloads/resume.pdf" download>Click to download CV</a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style is:global>
  /* Poster framing: black title bar on top, the map fills the rest on a thin
     warm-gray mat. Map internals key off --bg = white. */
  body.home { overflow: hidden; --bg: #ffffff; background: #b3aca0; }
</style>

<style>
  .top-bar {
    position: relative;
    height: 74px;
    background: #000;
    display: flex;
    align-items: center;
    padding: 0 1.6rem;
  }
  .logo {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    color: #fff;
    text-decoration: none;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }
  .logo img { background: #fff; border-radius: 7px; padding: 3px; align-self: center; }
  .logo-name { font-weight: 800; font-size: 1.7rem; letter-spacing: 0.005em; }
  .logo-sub { font-weight: 300; font-size: 1.35rem; color: #d7d2c8; }
  /* Centered on the bar as a whole (not relative to the logo), so the
     platform label stays put regardless of logo width. */
  .bar-section {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    color: #fff;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-weight: 700;
    font-size: 1.5rem;
  }
  .bar-section:empty { display: none; }
  .map-stage {
    position: relative;
    height: calc(100vh - 74px);
    padding: 0;
  }
  .map-wrap {
    width: 100%;
    height: 100%;
    overflow: hidden;
  }
  @media (max-width: 768px) {
    .top-bar { height: 60px; }
    .logo-name { font-size: 1.3rem; }
    .logo-sub { font-size: 1.05rem; }
    .map-stage { height: calc(100dvh - 60px); padding: 0; }
    :global(#station-board) { left: auto; right: 20px; top: auto; bottom: 20px; transform: none; width: min(230px, 82vw); }
    /* Rail docks to the bottom on mobile, not the left edge, so the paging
       button doesn't need the desktop rail clearance. */
    .edge-btn-left { left: 20px; }
  }

  /* ------------------------------------------------------------------ */
  /* Platform overlay: sits above the map panel, itself click-through   */
  /* except for its interactive children (the in-map engine drives its  */
  /* visibility/opacity/positioning; see src/scripts/ride.ts).          */
  #platform-ui {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 20;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  /* Edge paging buttons: vertically centered on the left/right edges of the
     map stage; the engine sets their background to the current line's hex. */
  .edge-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: auto;
    /* Sit above every platform card (which paint later in the DOM but at
       the default stacking order) so the buttons are never buried under a
       card and remain fully clickable. */
    z-index: 40;
    font: inherit;
    font-weight: 700;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.95rem;
    color: #fff;
    background: #131313;
    border: none;
    border-radius: 999px;
    padding: 0.65rem 1.2rem;
    cursor: pointer;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
    white-space: nowrap;
  }
  .edge-btn:hover { filter: brightness(1.12); }
  .edge-btn[hidden] { display: none; }
  .edge-btn-right { right: 20px; }
  /* Clears the persistent left rail (28px + ~230px wide) instead of
     sitting under/beside it. */
  .edge-btn-left { left: 270px; }

  /* Cards: absolutely positioned by the engine (left/top + GSAP transforms).
     No transform set here — GSAP owns it. */
  .platform-card {
    position: absolute;
    pointer-events: auto;
    background: #fff;
    border-radius: 10px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.22);
    padding: 0.7rem 0.85rem;
    box-sizing: border-box;
    text-decoration: none;
    color: inherit;
  }

  /* Music platform: full-width open rows instead of cards. The engine sets
     `left` per stop; `right: 4vw` lets each row's width flow to near the
     viewport edge. No card box, shadow, or radius — transparent rows over
     the map, separated by grid-line dividers. */
  .platform-row {
    position: absolute;
    pointer-events: auto;
    right: 4vw;
    box-sizing: border-box;
    background: transparent;
    box-shadow: none;
    border-radius: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 1.1rem;
    color: #1a1a1a;
  }
  /* Cover + title/artist/links, grouped like the original's .music-header:
     a fixed-width block so it doesn't compete for space with the waveform
     and meters that follow. */
  .row-header {
    flex: none;
    width: 290px;
    display: flex;
    align-items: center;
    gap: 1rem;
    min-width: 0;
  }
  /* Cover art, matching the original site's per-track thumbnail (enlarged
     from an icon-sized thumb to a real cover, per the original layout). */
  .row-cover {
    width: 100px;
    height: 100px;
    flex: none;
    border-radius: 6px;
    object-fit: cover;
    border: 1px solid rgba(26, 26, 26, 0.12);
  }
  .row-info { flex: 1 1 auto; min-width: 0; }
  .row-title { margin: 0; font-size: 1.15rem; font-weight: 700; line-height: 1.2; }
  .row-artist { margin: 0.2rem 0 0.4rem; font-size: 0.82rem; color: #6f6a60; font-weight: 600; }
  .row-links { display: flex; flex-wrap: wrap; gap: 0.6rem; font-size: 0.72rem; font-weight: 700; }
  .row-links a { color: #754fad; text-decoration: none; }
  .row-links a:hover { text-decoration: underline; }
  /* Icon-style play/pause button, matching the original's circular
     waveform-play-btn (not a text pill). Sits at the end of the row. */
  .row-play {
    flex: none;
    width: 56px;
    height: 56px;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border: 1.5px solid #754fad;
    border-radius: 50%;
    background: transparent;
    color: #754fad;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .row-play:hover { background: rgba(117, 79, 173, 0.12); }
  .row-play[aria-pressed='true'] { background: #754fad; color: #fff; }
  .row-play-icon { width: 20px; height: 20px; fill: currentColor; }
  .row-play .icon-pause { display: none; }
  .row-play[aria-pressed='true'] .icon-play { display: none; }
  .row-play[aria-pressed='true'] .icon-pause { display: block; }
  /* A modest strip like the original's (capped at its 270px max), flexing
     into whatever the fixed-size cover/play/meters leave over — mirroring
     the original's behavior in its own narrow window (769–1180px), where
     the wave is the flexible element. */
  .row-wave { flex: 1 1 auto; min-width: 100px; max-width: 270px; height: 56px; display: block; }
  .row-meters { display: flex; gap: 0.6rem; align-items: center; flex: none; }
  /* Position: relative + an absolutely-positioned label keeps the label out
     of the flow, so the group's box is exactly the canvas's box — nothing
     asymmetric pushes the canvas's own vertical center off the row's
     centerline, which is the world grid line the stop sits on (see
     ride.ts placeCards/parkPose: the row is centered on the stop via
     yPercent -50). Without this, the label's height below the canvas would
     drag the visual center down and the vectorscope's horizontal axis would
     no longer sit on the grid line. */
  .meter-group { position: relative; flex: none; }
  .meter-label {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    margin-top: 0.3rem;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: #6f6a60;
    text-transform: lowercase;
    white-space: nowrap;
  }
  /* Meter canvas CSS sizes mirror the original site's rendered clamps
     (style.css .frequency-canvas / .vectorscope-canvas / .vu-meter-canvas).
     The VU's earlier 76px width came from the canvas's *internal* width=""
     attribute rather than the original's rendered box — which is why it
     looked shrunken. music-player.ts re-sizes each backing store to the
     rendered box * devicePixelRatio, so CSS is the single source of truth. */
  .row-freq { display: block; width: clamp(220px, 22vw, 300px); height: 110px; }
  .row-vec { display: block; width: clamp(96px, 9vw, 110px); height: clamp(96px, 9vw, 110px); }
  .row-vu { display: block; width: clamp(120px, 11vw, 150px); height: 100px; }

  /* Grid-line dividers: thin ink lines that read as the map's own grid
     fading in. The engine positions them at the midpoints between music
     stops (which fall on 50-unit grid lines). Same left→right span as rows. */
  .platform-divider {
    position: absolute;
    right: 4vw;
    height: 1px;
    background: rgba(26, 26, 26, 0.16);
    transform: translateY(-50%);
    pointer-events: none;
  }

  /* The music row's usable width is only ~62% of the viewport (it starts
     right of the vertical line and ends at right:4vw), so the full meter
     family at original-site sizes (freq 282 + scope 110 + VU 141) plus
     cover/play/wave doesn't fit until ~1760px. The VU and vectorscope are
     the calibrated stars and always render at full size; the spectrum is
     the first to yield, exactly like the original drops its meters in its
     own too-narrow window (769–1180px). */
  @media (max-width: 1759px) {
    .meter-group-freq { display: none; }
  }

  @media (max-width: 1180px) {
    .row-meters { display: none; }
    .row-info { width: 200px; }
  }

  /* Project cards: the engine positions the <a> itself with GSAP transforms
     (xPercent/x), so hover scale/shadow live on an inner wrapper instead —
     applying transform to the positioned element would fight GSAP. */
  .card-project {
    /* Fallback for the instant before JS sizes it from the real stop pitch
       (see placeCards() in ride.ts) — actual width is set inline per card. */
    width: 270px;
    padding: 0;
    display: block;
    background: transparent;
    box-shadow: none;
    cursor: pointer;
  }
  .card-project .card-inner {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.22);
    /* Pure composited transform: always-on translateZ(0) keeps this element
       on its own GPU layer whether or not it's hovered, so hovering never
       toggles compositing (which otherwise causes a one-frame subpixel
       snap in the text below as font rasterization switches paths). */
    transform: translateZ(0) scale(1);
    transform-origin: center center;
    will-change: transform;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .card-project:hover .card-inner,
  .card-project:focus-visible .card-inner {
    transform: translateZ(0) scale(1.04);
    box-shadow: 0 20px 46px rgba(0, 0, 0, 0.32);
  }
  /* height is set inline by placeCards() to track the card's own (dynamic,
     now ~62% of the stop pitch) width; this is just a pre-JS fallback. */
  .card-project .thumb { width: 100%; height: 100px; object-fit: cover; display: block; }
  .card-project .body { padding: 0.55rem 0.65rem 0.65rem; }
  .card-project h3 { margin: 0 0 0.2rem; font-size: clamp(0.78rem, 1vw, 0.95rem); font-weight: 800; line-height: 1.2; }
  .card-project .summary {
    margin: 0 0 0.35rem;
    font-size: clamp(0.62rem, 0.72vw, 0.72rem);
    color: #444;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-project .tags { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 0.22rem; }
  .card-project .tags li { font-size: clamp(0.5rem, 0.56vw, 0.58rem); font-weight: 700; color: #d13d59; border: 1.1px solid #d13d59; border-radius: 999px; padding: 0.08rem 0.4rem; }

  /* Filter bar: pinned in the band between the top bar and the platform
     track, projects view only (toggled in showUI/hideUI). The full tag set
     (~25 pills) cannot be guaranteed to fit in two wrapped rows at every
     viewport, so this is a single dense row that scrolls horizontally
     rather than wrapping — wrapping risked pills sliding down far enough to
     cross the track/cards. Bounded left/right so it can never overlap the
     persistent left rail (28px + up to 230px wide) or the viewport edge. */
  #filter-bar {
    position: absolute;
    top: 84px;
    left: 270px;
    right: 20px;
    display: flex;
    flex-wrap: nowrap;
    overflow-x: auto;
    overflow-y: hidden;
    gap: 0.35rem;
    padding: 0.15rem 0.3rem;
    pointer-events: auto;
    scrollbar-width: thin;
    /* Subtle edge fade so the scrollable overflow reads as intentional. */
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0,
      #000 20px,
      #000 calc(100% - 20px),
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0,
      #000 20px,
      #000 calc(100% - 20px),
      transparent 100%
    );
  }
  #filter-bar[hidden] { display: none; }
  .filter-tag {
    flex: none;
    white-space: nowrap;
    font: inherit;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-weight: 500;
    font-size: 0.7rem;
    text-align: center;
    text-transform: lowercase;
    color: #4a453c;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(26, 26, 26, 0.2);
    border-radius: 3px;
    padding: 0.32rem 0.7rem;
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
  }
  .filter-tag.active,
  .filter-tag[aria-pressed='true'] {
    background: #d13d59;
    border-color: #d13d59;
    color: #fff;
  }
  .filter-tag:hover:not(.active) { border-color: #d13d59; color: #1a1a1a; }

  .card-about {
    width: 300px;
  }
  /* The bio card carries a portrait photo beside the text. Both children are
     stretched (align-items: stretch, the flex default) so the card's height
     is set purely by content — no fixed heights left over as a phantom
     white strip below the shorter of the two. */
  .card-about-bio {
    /* Wider, with a smaller photo, than the original design so the bio
       text needs fewer wrapped lines — the diagonal platform's stops sit
       closer together than this card is tall, so a shorter card leaves
       more headroom before the vertical stacking in placeCards() (ride.ts)
       has to push neighboring cards down to avoid it. */
    width: 430px;
    display: flex;
    align-items: stretch;
    gap: 0;
    padding: 0;
    overflow: hidden;
  }
  .about-label { margin: 0 0 0.4rem; font-size: 0.66rem; letter-spacing: 0.16em; text-transform: uppercase; color: #6f6a60; }
  .card-about-bio .photo {
    width: 130px;
    /* No fixed height: stretches to match the text column via the flex
       row's align-items: stretch, so object-fit: cover always fills the
       card's full (content-driven) height with no leftover gap. */
    flex: none;
    object-fit: cover;
    display: block;
  }
  .card-about-bio .bio {
    margin: 0;
    padding: 0.6rem 0.8rem;
    font-size: 0.78rem;
    line-height: 1.32;
    flex: 1 1 auto;
  }
  .stat-row { display: flex; gap: 0.5rem; }
  .stat-tile { flex: 1; background: #815e49; color: #fff; border-radius: 8px; padding: 0.5rem 0.6rem; display: flex; flex-direction: column; }
  .stat-value { font-size: 1.2rem; font-weight: 800; line-height: 1; }
  .stat-label { margin-top: 0.2rem; font-size: 0.68rem; opacity: 0.9; }
  .chips { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 0.3rem; }
  .chip { font-size: 0.64rem; font-weight: 700; border-radius: 999px; padding: 0.16rem 0.55rem; background: #eee7db; color: #3a352b; }
  /* Sized to its content (not the shared card width) so there's no dead
     space to the right of the button row — and wide enough that all four
     buttons sit on one line instead of wrapping. */
  .card-about-socials { width: fit-content; max-width: none; }

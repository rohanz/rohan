---
import Layout from '../layouts/Layout.astro';
import TransitMap from '../components/TransitMap.astro';
import StationBoard from '../components/StationBoard.astro';
import { getCollection } from 'astro:content';
import music from '../data/music.json';
import { SOCIALS } from '../data/socials';

interface Props {
  title: string;
  description: string;
  initialView?: 'music' | 'projects' | 'about';
}
const { title, description, initialView } = Astro.props;

// Unlisted projects (pages that exist but don't ride the line) are excluded
// from the platform entirely: no card, no tag-pill contribution, and — since
// paging is derived from the rendered cards — no page count impact.
const projects = (await getCollection('projects'))
  .filter((p) => !p.data.unlisted)
  .sort((a, b) => a.data.order - b.data.order);

// Filter pills: one per unique technology across all projects, matching the
// full tag set from the original site (wraps to two centered rows if needed).
// CURATED filter pills, not the raw union: with 11 projects the union is ~38
// tags in five rows — a wall where most filters match one project. One row of
// skills-level pills, each matching one or more underlying technology tags
// (ALIASES: the pill's data-filter carries its matched tags '||'-joined; the
// engine's applyFilter ORs across them). Cards still show their full
// technology lists; a pill whose aliases all vanish from the content is
// dropped automatically rather than rendering a dead filter.
const CURATED_PILLS: { label: string; match: string[] }[] = [
  { label: 'finance', match: ['Finance', 'Backtesting'] },
  { label: 'machine learning', match: ['Machine Learning'] },
  { label: 'fine-tuning', match: ['Fine-tuning', 'QLoRA'] },
  { label: 'evals', match: ['Evals'] },
  { label: 'ai agents', match: ['AI Agents'] },
  { label: 'data pipelines', match: ['Data Pipelines'] },
  { label: 'web scraping', match: ['Web Scraping'] },
  { label: 'dsp', match: ['DSP'] },
  { label: 'cloud infra', match: ['Cloud Infra'] },
  { label: 'devops', match: ['DevOps'] },
];
const allTags = new Set(projects.flatMap((p) => p.data.technologies));
const filterTags = CURATED_PILLS.filter((p) => p.match.some((t) => allTags.has(t)));

const stats = [
  { value: '1.3m+', label: 'streams' },
  { value: '8+', label: 'projects built' },
];

const tech = [
  'Python',
  'JavaScript',
  'React',
  'C++',
  'JUCE',
  'DSP',
  'OpenAI',
  'Codex',
  'Google Cloud',
  'Node.js',
  'Docker',
  'Git',
  'Linux',
  'DuckDB',
  'PostgreSQL',
  'Claude',
  'Gemini',
];

---
<Layout title={title} description={description} bodyClass="home" initialView={initialView}>
  <header class="top-bar" id="logo-bar">
    <a id="logo" class="logo" href="/" aria-label="rohan.jk — home">
      <img src="/logo.svg" width="34" height="34" alt="" />
      <span class="logo-name">rohan.jk</span>
    </a>
    <span id="bar-section" class="bar-section"></span>
  </header>

  <main id="main" class="map-stage">
    <!-- Page h1 for the map views (visually hidden — the map poster carries no
         visible page title). The card h3s below are left as-is deliberately:
         re-leveling them risks styling churn, and the h1→h3 skip is an
         accepted minor nit. -->
    <h1 class="sr-only">rohan.jk — interactive transit map</h1>
    <div class="map-wrap"><TransitMap /></div>
    <StationBoard />

    <div id="platform-ui" hidden>
      <button id="more-prev" class="edge-btn edge-btn-left" type="button" hidden>← Back</button>
      <button id="more-next" class="edge-btn edge-btn-right" type="button" hidden>More →</button>
      <!-- "x–y of N" range for the paged projects platform; text + position are
           owned by the ride engine (updateMoreButtons / placeProjectPaging). -->
      <span id="page-indicator" hidden aria-live="polite"></span>
      <div id="filter-bar" hidden>
        <button type="button" class="filter-tag active" data-filter="all" aria-pressed="true">all</button>
        {filterTags.map((t) => (
          <button type="button" class="filter-tag" data-filter={t.match.join('||')} aria-pressed="false">{t.label}</button>
        ))}
      </div>

      <div data-content="music" hidden>
        {Array.from({ length: music.length + 1 }).map(() => (
          <div class="platform-divider" data-divider="music" aria-hidden="true"></div>
        ))}
        {music.map((t) => (
          <div class="platform-row" data-card="music" data-audio-url={t.audio}>
            <div class="row-header">
              <img class="row-cover" src={t.cover} alt="" loading="lazy" />
              <div class="row-info">
                <h3 class="row-title">{t.title}</h3>
                <p class="row-artist">{t.artist}</p>
                <div class="row-links">
                  <a href={t.spotifyUrl} target="_blank" rel="noopener noreferrer">spotify</a>
                  <a href={t.appleMusicUrl} target="_blank" rel="noopener noreferrer">apple music</a>
                  <a href={t.youtubeUrl} target="_blank" rel="noopener noreferrer">youtube</a>
                </div>
              </div>
            </div>
            <!-- Order matches the original's waveform-player: play button,
                 then waveform, then meters (see main.js displayMusic). -->
            <button type="button" class="row-play" data-play aria-label={`Play snippet of ${t.title}`} aria-pressed="false">
              <svg class="row-play-icon icon-play" viewBox="0 0 24 24" aria-hidden="true"><path d="M7 5.5v13l11-6.5z" /></svg>
              <svg class="row-play-icon icon-pause" viewBox="0 0 24 24" aria-hidden="true"><path d="M6.5 5h4v14h-4zM13.5 5h4v14h-4z" /></svg>
            </button>
            <div class="meter-group meter-group-wave">
              <canvas class="row-wave" height="56" aria-hidden="true"></canvas>
              <span class="meter-label">wave</span>
            </div>
            <div class="row-meters" aria-hidden="true">
              <div class="meter-group meter-group-freq">
                <canvas class="row-freq" width="282" height="110"></canvas>
                <span class="meter-label">freq</span>
              </div>
              <div class="meter-group meter-group-stereo">
                <canvas class="row-vec" width="110" height="110"></canvas>
                <span class="meter-label">stereo</span>
              </div>
              <div class="meter-group meter-group-vu">
                <canvas class="row-vu" width="141" height="100"></canvas>
                <span class="meter-label">vu</span>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div data-content="projects" hidden>
        {projects.map((p) => (
          <a
            class="platform-card card-project"
            data-card="projects"
            data-tech={p.data.technologies.join('|')}
            href={`/projects/${p.id}`}
            data-astro-prefetch="hover"
          >
            <div class="card-inner">
              <img class="thumb" src={p.data.image} alt="" loading="lazy" />
              <div class="body">
                <h3>{p.data.title}</h3>
                <p class="summary">{p.data.summary}</p>
                <ul class="tags">
                  {p.data.technologies.map((t) => <li>{t}</li>)}
                </ul>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div data-content="about" hidden>
        <!-- Six identical cards, paired left/right on three diagonal stops.
             Source order = card index; even index → right of line, odd → left.
             Stop 1: photo (R) + bio (L); Stop 2: stats (R) + tech (L);
             Stop 3: socials (R) + cv (L). The photo/bio split mirrors the
             original site's separate bento-photo and bento-bio cards. -->
        <div class="platform-card card-about card-about-photo" data-card="about">
          <img class="photo" src="/assets/images/profile.webp" alt="Rohan" loading="lazy" />
        </div>

        <div class="platform-card card-about card-about-bio" data-card="about">
          <h3 class="about-label">Bio</h3>
          <p class="bio">hi, i'm rohan, a computer engineering student at ntu, singapore. i build end-to-end products with AI, from data pipelines and cloud infrastructure to mobile apps and everything in between. outside of code, i write, produce and record music. feel free to reach out below!</p>
        </div>

        <div class="platform-card card-about card-about-stats" data-card="about">
          <h3 class="about-label">Stats</h3>
          <div class="stat-row">
            {stats.map((s) => (
              <div class="stat-tile">
                <span class="stat-value">{s.value}</span>
                <span class="stat-label">{s.label}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="platform-card card-about card-about-tech" data-card="about">
          <h3 class="about-label">Tech stack</h3>
          <ul class="chips">
            {tech.map((name) => (
              <li class="chip">{name}</li>
            ))}
          </ul>
        </div>

        <div class="platform-card card-about card-about-socials" data-card="about">
          <h3 class="about-label">Socials</h3>
          <div class="social-buttons">
            {SOCIALS.map((s) => (
              <a class="social-btn" href={s.href} target="_blank" rel="noopener noreferrer">{s.name}</a>
            ))}
          </div>
        </div>

        <div class="platform-card card-about card-about-cv" data-card="about">
          <h3 class="about-label">CV</h3>
          <a class="cv-btn" href="/downloads/resume.pdf" download>Download CV</a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style is:global>
  /* Poster framing: black title bar on top, the map fills the rest on a thin
     warm-gray mat. Map internals key off --bg = white. */
  body.home { overflow: hidden; --bg: #ffffff; background: #b3aca0; }
</style>

<style>
  .top-bar {
    position: relative;
    height: var(--topbar-h);
    background: var(--bar-bg);
    display: flex;
    align-items: center;
    padding: 0 1.6rem;
  }
  .logo {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    color: #fff;
    text-decoration: none;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }
  /* White mark, no box: the solid logo glyph is inverted to white so it sits
     straight on the coloured bar with no card behind it. */
  .logo img { filter: brightness(0) invert(1); align-self: center; }
  .logo-name { font-weight: 800; font-size: 1.7rem; letter-spacing: 0.005em; }
  /* Centered on the bar as a whole (not relative to the logo), so the
     platform label stays put regardless of logo width. */
  .bar-section {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    color: #fff;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-weight: 700;
    font-size: 1.5rem;
  }
  .bar-section:empty { display: none; }
  .map-stage {
    position: relative;
    height: calc(100vh - var(--topbar-h));
    /* Progressive enhancement: dvh tracks the dynamic URL-bar viewport on
       tablet-band Safari; browsers without dvh keep the vh line above. */
    height: calc(100dvh - var(--topbar-h));
    padding: 0;
  }
  .map-wrap {
    width: 100%;
    height: 100%;
    overflow: hidden;
    /* Hidden until the engine applies the initial camera pose (init() adds
       .map-ready). The SVG otherwise paints once at the identity transform —
       before the deferred script runs — then jumps to the real pose, which read
       as a "flash offset then snap back" on reload. A short fade-in on the
       already-correct pose replaces that with a clean appear. */
    opacity: 0;
  }
  .map-wrap.map-ready {
    opacity: 1;
    transition: opacity 0.25s ease;
  }
  @media (max-width: 768px) {
    .top-bar { height: 60px; }
    .logo-name { font-size: 1.3rem; }
    .map-stage { height: calc(100dvh - 60px); padding: 0; }
  }

  /* ------------------------------------------------------------------ */
  /* Platform overlay: sits above the map panel, itself click-through   */
  /* except for its interactive children (the in-map engine drives its  */
  /* visibility/opacity/positioning; see src/scripts/ride.ts).          */
  #platform-ui {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 20;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  /* Edge paging buttons. The engine sets their background to the current
     line's hex, and on desktop projects (the only view that ever shows them)
     placeProjectPaging overrides top/left/transform inline each layout pass,
     centering each button BELOW its outer card — the edge-anchored pose here
     only covers the instant before the first placement. */
  .edge-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: auto;
    /* Sit above every platform card (which paint later in the DOM but at
       the default stacking order) so the buttons are never buried under a
       card and remain fully clickable. */
    z-index: 40;
    font: inherit;
    font-weight: 700;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.95rem;
    color: #fff;
    background: var(--ink-strong);
    border: none;
    border-radius: 999px;
    padding: 0.65rem 1.2rem;
    cursor: pointer;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
    white-space: nowrap;
  }
  .edge-btn:hover { filter: brightness(1.12); }
  .edge-btn[hidden] { display: none; }
  /* Page range ("4–6 of 10") — quiet signage centred between the paging
     buttons at the same row (positioned by placeProjectPaging). */
  #page-indicator {
    position: absolute;
    z-index: 40;
    pointer-events: none;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-weight: 600;
    font-size: calc(0.85rem * var(--card-scale, 1));
    color: var(--muted);
    white-space: nowrap;
    /* Vertically align with the pill buttons beside it. */
    line-height: calc(0.95rem + 1.3rem);
  }
  #page-indicator[hidden] { display: none; }
  @media (max-width: 768px) { #page-indicator { display: none; } }
  /* Pre-placement fallbacks only (see above): right edge / just right of the
     fixed docked-rail width (--rail-w). */
  .edge-btn-right { right: 20px; }
  .edge-btn-left { left: calc(var(--rail-w) + 20px); }

  /* On narrow viewports the right-edge paging button competes with the
     rightmost card for horizontal space, so drop the pair to the bottom
     corners (music never paginates, so only projects/about are affected,
     and their cards sit clear of the bottom band). */
  @media (max-width: 1000px) {
    .edge-btn { top: auto; bottom: 22px; transform: none; }
    .edge-btn-left { left: 24px; }
    .edge-btn-right { right: 24px; }
  }

  /* Cards: absolutely positioned by the engine (left/top + GSAP transforms).
     No transform set here — GSAP owns it. */
  .platform-card {
    position: absolute;
    pointer-events: auto;
    background: #fff;
    border-radius: 10px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.22);
    padding: 0.7rem 0.85rem;
    box-sizing: border-box;
    text-decoration: none;
    color: inherit;
  }

  /* Music platform: full-width open rows instead of cards. The engine sets
     `left` per stop; `right: 4vw` lets each row's width flow to near the
     viewport edge. No card box, shadow, or radius — transparent rows over
     the map, separated by grid-line dividers. */
  .platform-row {
    position: absolute;
    pointer-events: auto;
    right: 4vw;
    box-sizing: border-box;
    background: transparent;
    box-shadow: none;
    border-radius: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 1.1rem;
    color: var(--ink);
    /* Ceiling on how tall any in-row visual (cover / waveform / meters) may
       grow. The rows are laid out on the map with a vertical PITCH that scales
       with viewport HEIGHT (~0.164 * vh — see parkPose 'v': the stops are 100
       world-units apart and the scale is height-derived), while the visual
       sizes below otherwise scale with viewport WIDTH (vw). On a short (or
       short-and-wide) viewport the width-driven visuals would outgrow the
       height-driven pitch and bleed into the neighbouring song row. Capping
       every tall element at ~13vh keeps each row's content inside its own band
       with clear daylight to the next, while the vw-based clamps still let
       things grow "bigger on large screens" whenever height allows. */
    --viz-max-h: 13vh;
  }
  /* Cover + title/artist/links, grouped like the original's .music-header:
     a fixed-width block so it doesn't compete for space with the waveform
     and meters that follow. */
  .row-header {
    flex: none;
    /* Grows on wide viewports (floors at the original 290px so narrow screens
       are unchanged) so the cover + title block scales with the bigger rows. */
    width: clamp(290px, 21vw, 380px);
    display: flex;
    align-items: center;
    gap: 1rem;
    min-width: 0;
  }
  /* Cover art, matching the original site's per-track thumbnail (enlarged
     from an icon-sized thumb to a real cover, per the original layout).
     Scales up on large screens; floors at the original 100px. */
  .row-cover {
    width: min(clamp(100px, 6.5vw, 132px), var(--viz-max-h));
    height: min(clamp(100px, 6.5vw, 132px), var(--viz-max-h));
    flex: none;
    border-radius: 6px;
    object-fit: cover;
    border: 1px solid rgba(26, 26, 26, 0.12);
  }
  .row-info { flex: 1 1 auto; min-width: 0; }
  .row-title { margin: 0; font-size: clamp(1.15rem, 1.35vw, 1.5rem); font-weight: 700; line-height: 1.2; }
  .row-artist { margin: 0.2rem 0 0.4rem; font-size: clamp(0.82rem, 0.92vw, 1rem); color: var(--muted-2); font-weight: 600; }
  .row-links { display: flex; flex-wrap: wrap; gap: 0.6rem; font-size: 0.72rem; font-weight: 700; }
  .row-links a { color: var(--line-music); text-decoration: none; }
  .row-links a:hover { text-decoration: underline; }
  /* Icon-style play/pause button, matching the original's circular
     waveform-play-btn (not a text pill). Sits at the end of the row. */
  .row-play {
    /* Positioned by the engine onto a grid intersection (placeMusicViz sets
       `left`; top:50% + translate centres it on the stop's grid line). */
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%);
    /* ~0.6 of a grid square: reads as sitting on the grid without dominating
       the row (a full square was too big a circle). */
    width: calc(var(--grid, 64px) * 0.6);
    height: calc(var(--grid, 64px) * 0.6);
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border: 1.5px solid var(--line-music);
    border-radius: 50%;
    background: transparent;
    color: var(--line-music);
    transition: background 0.2s ease, color 0.2s ease;
  }
  .row-play:hover { background: rgba(117, 79, 173, 0.12); }
  .row-play[aria-pressed='true'] { background: var(--line-music); color: #fff; }
  .row-play-icon { width: clamp(20px, 1.5vw, 26px); height: clamp(20px, 1.5vw, 26px); fill: currentColor; }
  .row-play .icon-pause { display: none; }
  .row-play[aria-pressed='true'] .icon-play { display: none; }
  .row-play[aria-pressed='true'] .icon-pause { display: block; }
  /* A modest strip like the original's (capped at its 270px max), flexing
     into whatever the fixed-size cover/play/meters leave over — mirroring
     the original's behavior in its own narrow window (769–1180px), where
     the wave is the flexible element. */
  /* Waveform: two grid squares wide, one tall. Wrapped in a .meter-group so the
     engine centres it on a grid intersection and it carries a label like the
     other visuals. */
  .row-wave {
    width: calc(var(--grid, 64px) * 2);
    height: var(--grid, 64px);
    display: block;
  }
  /* Each meter is placed individually on the grid, so the wrapper just passes
     its children through rather than forming a flex strip. */
  .row-meters { display: contents; }
  /* Position: relative + an absolutely-positioned label keeps the label out
     of the flow, so the group's box is exactly the canvas's box — nothing
     asymmetric pushes the canvas's own vertical center off the row's
     centerline, which is the world grid line the stop sits on (see
     ride.ts placeCards/parkPose: the row is centered on the stop via
     yPercent -50). Without this, the label's height below the canvas would
     drag the visual center down and the vectorscope's horizontal axis would
     no longer sit on the grid line. */
  .meter-group {
    /* Positioned by the engine, centred on its own grid intersection. The label
       stays absolute (below the canvas), so the group's box is exactly the
       canvas box and translate(-50%,-50%) lands the canvas centre on the grid. */
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%);
  }
  /* All meter labels share ONE baseline regardless of their canvas's height:
     every group is vertically centred on the stop's grid line, so `top:50%` is
     that same centreline for each, and a fixed offset below it (clearing the
     tallest meter — freq at ~0.78 squares half-height) lands all labels on the
     same row. Without this, a taller canvas (e.g. the stereo scope) pushed its
     label lower than the others. */
  .meter-label {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translateX(-50%);
    /* Purely grid-proportional (no fixed px, which would dominate at small
       scale and shove the label past the divider): 0.7 squares below the
       centreline clears the tallest meter (~0.65 sq half-height) and still
       leaves the label inside the one-square band. */
    margin-top: calc(var(--grid, 64px) * 0.7);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--muted-2);
    text-transform: lowercase;
    white-space: nowrap;
  }
  /* Meter canvas CSS sizes mirror the original site's rendered clamps
     (style.css .frequency-canvas / .vectorscope-canvas / .vu-meter-canvas).
     The VU's earlier 76px width came from the canvas's *internal* width=""
     attribute rather than the original's rendered box — which is why it
     looked shrunken. music-player.ts re-sizes each backing store to the
     rendered box * devicePixelRatio, so CSS is the single source of truth. */
  /* Heights capped by --viz-max-h so meters never outgrow the row pitch on
     short screens; widths shrink in lock-step (calc keeps each canvas's native
     aspect ratio — freq 282:110≈2.56, vec 1:1, vu 141:100≈1.41 — so the
     WebAudio drawings, which read their own rendered box, stay undistorted). */
  /* Each meter is GRID-SIZED on its width (in whole squares) but its HEIGHT is
     derived from the canvas's NATIVE aspect ratio so the WebAudio drawing is
     never stretched — the width sits on the grid, the proportions stay true. */
  /* Freq analyser: 3 squares wide (centred in a 4-square slot, half a square of
     air each side), native 282:110 ≈ 2.564 → height 3/2.564 ≈ 1.17. Short enough
     that the meter plus its label always fit inside the one-square band. */
  .row-freq {
    display: block;
    width: calc(var(--grid, 64px) * 3);
    height: calc(var(--grid, 64px) * 1.17);
  }
  /* Vectorscope: 1.3 squares, native 1:1 (square) — undistorted. */
  .row-vec {
    display: block;
    width: calc(var(--grid, 64px) * 1.3);
    height: calc(var(--grid, 64px) * 1.3);
  }
  /* VU: 1.6 squares wide, native 141:100 = 1.41 → height 1.6/1.41 ≈ 1.135. */
  .row-vu {
    display: block;
    width: calc(var(--grid, 64px) * 1.6);
    height: calc(var(--grid, 64px) * 1.135);
  }

  /* Grid-line dividers: thin ink lines that read as the map's own grid
     fading in. The engine positions them at the midpoints between music
     stops (which fall on 50-unit grid lines). Same left→right span as rows. */
  .platform-divider {
    position: absolute;
    right: 4vw;
    height: 1px;
    background: rgba(26, 26, 26, 0.16);
    transform: translateY(-50%);
    pointer-events: none;
  }

  /* Responsive drop-out is now positional, not width-keyed: the engine hides any
     grid-placed visual that would collide with the title block or run off the
     right edge (see placeMusicViz), so the meters shed gracefully as the map
     narrows without hard-coded breakpoints. */

  /* Project cards: the engine positions the <a> itself with GSAP transforms
     (xPercent/x), so hover scale/shadow live on an inner wrapper instead —
     applying transform to the positioned element would fight GSAP. */
  .card-project {
    /* Fallback for the instant before JS sizes it from the real stop pitch
       (see placeCards() in ride.ts) — actual width is set inline per card. */
    width: 270px;
    padding: 0;
    display: block;
    background: transparent;
    box-shadow: none;
    cursor: pointer;
  }
  .card-project .card-inner {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    /* Fill the anchor's (JS-equalized) height and pin .tags to the bottom, so
       the per-page height equalization reads as one uniform strip — a shorter
       card's slack lands between summary and tags, not as bottom whitespace. */
    height: 100%;
    display: flex;
    flex-direction: column;
    /* No drop shadow — a hairline border gives just enough edge definition on the
       map background without the heavy lifted look. */
    border: 1px solid rgba(26, 26, 26, 0.12);
    /* Hover = a small LIFT (translateY), not a scale — same as the original site
       and the industry norm. translate moves the card as a unit without resampling
       its raster, so the text stays perfectly crisp (a scale would GPU-stretch the
       text bitmap and soften it). The border darkens alongside as a second cue. */
    transition: transform 0.18s ease, border-color 0.18s ease;
  }
  .card-project:hover .card-inner,
  .card-project:focus-visible .card-inner {
    transform: translateY(-3px);
    border-color: rgba(26, 26, 26, 0.4);
  }
  /* height is set inline by placeCards() to track the card's own (dynamic,
     now ~62% of the stop pitch) width; this is just a pre-JS fallback. */
  .card-project .thumb { width: 100%; height: 100px; object-fit: cover; display: block; }
  /* Flex column so the tags pin to the BOTTOM of the (uniform-height) card while
     the title + summary sit at the top — mirroring the original site's cards. The
     min-height fixes every card to one size regardless of tag count. */
  .card-project .body {
    padding: calc(0.6rem * var(--card-scale, 1)) calc(0.7rem * var(--card-scale, 1)) calc(0.7rem * var(--card-scale, 1));
    display: flex;
    flex-direction: column;
    /* min-height grows with the box on big monitors (--card-scale, set by
       placeCards) so the card's proportions hold and it doesn't read sparse. */
    min-height: calc(200px * var(--card-scale, 1));
    flex: 1; /* body absorbs the equalized height; .tags below pins to bottom */
  }
  /* Title: closer to the original's weight (700, not 800). Capped at two lines so
     a long name can't unbalance the card; the flex column + body min-height keep
     every card the same height regardless of how many lines it actually uses. */
  .card-project h3 {
    margin: 0 0 0.3rem;
    font-size: calc(clamp(0.82rem, 1.05vw, 1rem) * var(--card-scale, 1));
    font-weight: 700;
    line-height: 1.25;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  /* Summary: the original site's proportions (larger, airy line-height, secondary
     grey) and up to three lines rather than two. */
  .card-project .summary {
    margin: 0;
    font-size: calc(clamp(0.68rem, 0.8vw, 0.8rem) * var(--card-scale, 1));
    color: var(--muted-2);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  /* Tags pinned to the bottom of the card (margin-top:auto pushes them past the
     flexible gap under the summary), so every card's tag block sits on the same
     baseline regardless of summary length — like the original's cards. */
  .card-project .tags {
    list-style: none;
    margin: 0.7rem 0 0;
    margin-top: auto;
    padding: 0;
    display: flex;
    /* Tags aim for a SINGLE row per card. flex-wrap stays `wrap` (not nowrap) as
       a graceful-overflow safety net: a tag-heavy card (e.g. careersphere's 8
       techs) drops the overflow to a second row rather than truncating or
       spilling past the card edge — the standing rule is show ALL techs. Most
       cards fit one row at the tightened pill metrics below. */
    flex-wrap: wrap;
    align-content: flex-start;
    gap: calc(0.2rem * var(--card-scale, 1));
  }
  /* Match the .filter-tag pills above exactly (font, weight, colour, white fill,
     border, squared 3px corners, lowercase) — just a smaller font to fit the
     card — so the two tag sets read as one system. */
  .card-project .tags li {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-weight: 500;
    font-size: calc(clamp(0.58rem, 0.52vw, 0.62rem) * var(--card-scale, 1));
    text-transform: lowercase;
    white-space: nowrap;
    color: var(--tag-ink);
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(26, 26, 26, 0.2);
    border-radius: 3px;
    padding: calc(0.16rem * var(--card-scale, 1)) calc(0.4rem * var(--card-scale, 1));
  }
  /* Short laptop screens: below ~700px of viewport height the parked track
     (0.42 of the stage, pinned there by the filter bar just above it) leaves
     too little room under it for a full-budget card — the fullest card's tag
     pills fell past the fold. Trim the text budget: two summary lines instead
     of three, a slightly tighter body, and smaller tag pills. placeCards()
     trims the thumb ratio (0.56 → 0.44) on the same class of screens, so the
     whole card compresses in proportion and its bottom clears the viewport. */
  @media (max-height: 700px) {
    .card-project .body { min-height: 150px; padding: 0.5rem 0.6rem 0.55rem; }
    .card-project h3 { font-size: 0.78rem; }
    .card-project .summary { -webkit-line-clamp: 2; }
    .card-project .tags { gap: 0.24rem; }
    .card-project .tags li { font-size: 0.52rem; padding: 0.15rem 0.4rem; }
  }

  /* Filter bar: pinned in the band between the top bar and the platform
     track, projects view only (toggled in showUI/hideUI). Wraps into
     multiple centered rows (like the original's .projects-filter-bar:
     display:flex; flex-wrap:wrap) rather than one horizontally-scrolling
     line. Bounded left/right so it can never overlap the persistent left
     rail (28px + up to 230px wide) or the viewport edge; the projects
     park pose (ride.ts parkPose 'h') anchors the track low enough that the
     wrapped rows never reach the stops/cards/ticks. Below the breakpoint
     the band can't hold the full tag set without crowding the track, so it
     degrades gracefully to hidden — exactly as the original does. */
  #filter-bar {
    position: absolute;
    top: calc(var(--topbar-h) + 4px);
    /* A centered block within the content region to the RIGHT of the docked
       rail. Sized for the CURATED one-row pill set (~11 pills ≈ 1020px): on
       ordinary laptops and up it reads as a single row above the track; it
       wraps to two tidy rows only on narrower stages. Centering via
       margin-inline:auto between the rail edge and the viewport edge. */
    left: var(--rail-w);
    right: 0;
    /* The pill set grows with --card-scale (big-monitor card bump), so the
       band's cap must grow in lock-step or the enlarged pills wrap to a
       second row on exactly the screens with the most room. */
    max-width: calc(1040px * var(--card-scale, 1));
    margin-inline: auto;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-content: flex-start;
    gap: calc(0.4rem * var(--card-scale, 1)) calc(0.45rem * var(--card-scale, 1));
    padding: 0.1rem 0.3rem;
    pointer-events: auto;
  }
  #filter-bar[hidden] { display: none; }
  /* Narrow viewports: the full 31-pill set would wrap into too many rows to
     clear the track, so hide the filter UI rather than crowd it (graceful
     fallback, matching the original site's own filter-bar breakpoint). */
  @media (max-width: 1000px) {
    #filter-bar { display: none; }
  }
  .filter-tag {
    flex: none;
    white-space: nowrap;
    font: inherit;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-weight: 500;
    /* Grows with --card-scale (set on #platform-ui by placeCards) so the pills
       track the big-monitor card bump in lock-step with the card tags. */
    font-size: calc(0.74rem * var(--card-scale, 1));
    text-align: center;
    text-transform: lowercase;
    color: var(--tag-ink);
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(26, 26, 26, 0.2);
    border-radius: 3px;
    padding: calc(0.32rem * var(--card-scale, 1)) calc(0.7rem * var(--card-scale, 1));
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
  }
  .filter-tag.active,
  .filter-tag[aria-pressed='true'] {
    background: var(--line-projects);
    border-color: var(--line-projects);
    color: #fff;
  }
  .filter-tag:hover:not(.active) { border-color: var(--line-projects); color: var(--ink); }

  /* About platform: UNIFORM station cards. Every card is the same width and
     shares a min-height (both set inline by placeCards()/aboutGeom() in
     ride.ts, scaled to the viewport with clamp-like bounds), so the diagonal
     run reads as evenly-spaced identical cards rather than a jumble of sizes.
     Content is vertically centered in the box; the bio card keeps its
     photo-beside-text row. overflow:hidden is a safety net against rare
     content overrun so a card can never grow past the shared height and
     collide with its neighbour. */
  .card-about {
    width: 300px; /* pre-JS fallback; real W/H set inline by aboutGeom() */
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    /* Gap scales with the card too, so the label→content spacing shrinks on small
       cards rather than eating the room the content needs. */
    gap: calc(0.5rem * var(--about-scale, 1));
    overflow: hidden;
  }
  .about-label {
    margin: 0;
    flex: none;
    /* Floored: the small-caps label must stay legible even when the shrunk
       diagonal drives --about-scale well below 1 on laptop viewports. */
    font-size: max(9px, calc(clamp(0.66rem, 0.85vw, 0.8rem) * var(--about-scale, 1)));
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted-2);
  }
  /* Photo card: image sits inset within the uniform box with a thin frame,
     rather than bleeding edge to edge. */
  .card-about-photo { padding: 0.4rem; }
  .card-about-photo .photo {
    flex: 1;
    width: 100%;
    height: 100%;
    min-height: 0;
    object-fit: cover;
    display: block;
    border: 1.5px solid var(--ink-warm);
    border-radius: 6px;
  }
  /* Bio card: text-only now (photo split into its own card), sized up to fill
     the box comfortably. */
  .card-about-bio .bio {
    margin: 0;
    flex: 1;
    /* Top-aligned: the paragraph starts just under the "BIO" label and flows
       down, rather than being vertically centred in the box. */
    display: block;
    /* Floored at 10.5px: the un-floored scale product fell to ~8px on laptop
       viewports (illegible). The card has vertical headroom at those scales,
       so flooring the font is safe; line-height tightens slightly only when
       the floor is what's in effect (font-size never exceeds 10.5px/1.3 ratio
       territory on large screens, where the scaled size is bigger anyway). */
    font-size: max(10.5px, calc(clamp(0.72rem, 0.92vw, 0.98rem) * var(--about-scale, 1)));
    /* Line-height tracks the UN-floored font product (1.3×), floored at 12px.
       On large screens the product exceeds 12px so nothing changes; when the
       10.5px font floor is in effect the leading compresses toward 12px/10.5px
       ≈ 1.14, which is what lets the floored (larger) text still fit the
       shrunk card without clipping. */
    line-height: max(12px, calc(1.3 * clamp(0.72rem, 0.92vw, 0.98rem) * var(--about-scale, 1)));
    color: var(--ink-warm);
  }
  /* Stats: two tiles that stretch to fill the box height. */
  .stat-row { display: flex; gap: 0.55rem; flex: 1; min-height: 0; }
  .stat-tile { flex: 1; background: var(--line-about); color: #fff; border-radius: 8px; padding: 0.7rem 0.8rem; display: flex; flex-direction: column; justify-content: center; gap: 0.35rem; }
  .stat-value { font-size: calc(clamp(1.5rem, 2.4vw, 2.3rem) * var(--about-scale, 1)); font-weight: 800; line-height: 1; }
  .stat-label { font-size: max(9px, calc(clamp(0.7rem, 0.95vw, 0.86rem) * var(--about-scale, 1))); opacity: 0.92; }
  /* Tech pills: fill the box, wrapping and vertically centred. Pills (font +
     padding + gap) scale with the card so 16 of them never overflow a shrunk box. */
  /* align-content: flex-start anchors the pills just below the label and lets
     them grow DOWN — never up over the "tech stack" label — if space is tight. */
  .chips { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; align-content: flex-start; flex: 1; min-height: 0; gap: calc(0.36rem * var(--about-scale, 1)); }
  /* Chip line-height pins the previously-inherited 1.6× ratio to the
     UN-floored font product (floored at 9.9px = 1.1× the 9px font floor):
     identical on large screens, but compressed rows when the font floor binds
     so all 16 floored pills still fit the shrunk tech-stack card. */
  .chip { font-size: max(9px, calc(clamp(0.62rem, 0.85vw, 0.76rem) * var(--about-scale, 1))); line-height: max(9.9px, calc(1.6 * clamp(0.62rem, 0.85vw, 0.76rem) * var(--about-scale, 1))); font-weight: 700; border-radius: 999px; padding: calc(0.26rem * var(--about-scale, 1)) calc(0.62rem * var(--about-scale, 1)); background: #eee7db; color: #3a352b; }
  /* Socials: 2×2 grid of chunky buttons that STRETCH to fill the box, so the
     four links occupy the uniform card as fully as the other cards' content. */
  .social-buttons { display: grid; grid-template-columns: 1fr 1fr; grid-auto-rows: 1fr; gap: 0.6rem; flex: 1; min-height: 0; }
  .social-btn { display: flex; align-items: center; justify-content: center; text-decoration: none; font-weight: 700; font-size: max(11px, calc(clamp(0.9rem, 1.15vw, 1.12rem) * var(--about-scale, 1))); color: #fff; background: var(--line-about); border-radius: 8px; padding: 0.7rem 0.6rem; }
  .social-btn:hover { filter: brightness(1.12); }
  /* CV: label stays top-left like every other About card (inherits
     .card-about's flex-start column flow); the button is then centred in
     the remaining space below it via auto margins, so it reads as a normal,
     comfortably-sized button rather than a giant block filling the card. */
  .cv-btn {
    display: inline-flex;
    flex: none;
    align-items: center;
    justify-content: center;
    margin: auto;
    width: auto;
    max-width: 78%;
    text-align: center;
    text-decoration: none;
    font-weight: 800;
    font-size: max(11px, calc(clamp(0.95rem, 1.2vw, 1.1rem) * var(--about-scale, 1)));
    color: #fff;
    background: var(--line-about);
    border-radius: 8px;
    padding: calc(0.85rem * var(--about-scale, 1)) calc(1.9rem * var(--about-scale, 1));
  }
  .cv-btn:hover { filter: brightness(1.12); }
</style>


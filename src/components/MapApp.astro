---
import Layout from '../layouts/Layout.astro';
import TransitMap from '../components/TransitMap.astro';
import StationBoard from '../components/StationBoard.astro';
import { getCollection } from 'astro:content';
import music from '../data/music.json';

interface Props {
  title: string;
  description: string;
  initialView?: 'music' | 'projects' | 'about';
}
const { title, description, initialView } = Astro.props;

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);

// Filter pills: one per technology that shows up on 2+ projects, so the bar
// doesn't balloon with one-off tags.
const techCounts = new Map<string, number>();
projects.forEach((p) => {
  new Set(p.data.technologies).forEach((t) => techCounts.set(t, (techCounts.get(t) ?? 0) + 1));
});
const filterTags = Array.from(techCounts.entries())
  .filter(([, count]) => count >= 2)
  .map(([t]) => t)
  .sort();

const stats = [
  { value: '1.3m+', label: 'streams' },
  { value: '8+', label: 'projects built' },
];

const tech = [
  'Python',
  'JavaScript',
  'React',
  'C++',
  'JUCE',
  'DSP',
  'OpenAI',
  'Codex',
  'Google Cloud',
  'Node.js',
  'Docker',
  'Git',
  'Linux',
  'DuckDB',
  'PostgreSQL',
  'Claude',
  'Gemini',
];

const socials: [string, string][] = [
  ['github', 'https://github.com/rohanz'],
  ['spotify', 'https://open.spotify.com/artist/3I1V2FxqX2qs3zrUY0fCPp'],
  ['instagram', 'https://www.instagram.com/rrohan.jk/'],
  ['linkedin', 'https://www.linkedin.com/in/rohan-jk'],
];
---
<Layout title={title} description={description} bodyClass="home" initialView={initialView}>
  <header class="top-bar" id="logo-bar">
    <a id="logo" class="logo" href="/" aria-label="rohan.jk — home">
      <img src="/logo.svg" width="34" height="34" alt="" />
      <span class="logo-name">rohan.jk</span>
      <span class="logo-sub">system map</span>
    </a>
    <span id="bar-section" class="bar-section"></span>
  </header>

  <main id="main" class="map-stage">
    <div class="map-wrap"><TransitMap /></div>
    <StationBoard />

    <div id="platform-ui" hidden>
      <button id="back-map" type="button">← Back to map</button>
      <button id="more-prev" class="edge-btn edge-btn-left" type="button" hidden>← Back</button>
      <button id="more-next" class="edge-btn edge-btn-right" type="button" hidden>More projects →</button>
      <div id="filter-bar" hidden>
        <button type="button" class="filter-tag active" data-filter="all" aria-pressed="true">all</button>
        {filterTags.map((t) => (
          <button type="button" class="filter-tag" data-filter={t} aria-pressed="false">{t}</button>
        ))}
      </div>

      <div data-content="music" hidden>
        {Array.from({ length: music.length + 1 }).map(() => (
          <div class="platform-divider" data-divider="music" aria-hidden="true"></div>
        ))}
        {music.map((t) => (
          <div class="platform-row" data-card="music" data-audio-url={t.audio}>
            <div class="row-info">
              <h3 class="row-title">{t.title}</h3>
              <p class="row-artist">{t.artist}</p>
              <div class="row-links">
                <a href={t.spotifyUrl} target="_blank" rel="noopener noreferrer">spotify</a>
                <a href={t.appleMusicUrl} target="_blank" rel="noopener noreferrer">apple music</a>
                <a href={t.youtubeUrl} target="_blank" rel="noopener noreferrer">youtube</a>
              </div>
            </div>
            <canvas class="row-wave" height="56" aria-hidden="true"></canvas>
            <div class="row-meters">
              <div class="meter-group">
                <canvas class="row-freq" width="280" height="110"></canvas>
                <span class="meter-label">freq</span>
              </div>
              <div class="meter-group">
                <canvas class="row-vec" width="110" height="110"></canvas>
                <span class="meter-label">stereo</span>
              </div>
              <div class="meter-group">
                <canvas class="row-vu" width="76" height="110"></canvas>
                <span class="meter-label">vu</span>
              </div>
            </div>
            <button type="button" class="row-play" data-play aria-pressed="false">preview</button>
          </div>
        ))}
      </div>

      <div data-content="projects" hidden>
        {projects.map((p) => (
          <a
            class="platform-card card-project"
            data-card="projects"
            data-tech={p.data.technologies.join('|')}
            href={`/projects/${p.id}`}
            data-astro-prefetch="hover"
          >
            <div class="card-inner">
              <img class="thumb" src={p.data.image} alt="" loading="lazy" />
              <div class="body">
                <h3>{p.data.title}</h3>
                <p class="summary">{p.data.summary}</p>
                <ul class="tags">
                  {p.data.technologies.slice(0, 3).map((t) => <li>{t}</li>)}
                </ul>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div data-content="about" hidden>
        <div class="platform-card card-about card-about-bio" data-card="about">
          <img class="photo" src="/assets/images/profile.webp" alt="" loading="lazy" />
          <p class="bio">hi, i'm rohan, a computer engineering student at ntu, singapore. i build end-to-end products with AI, from data pipelines and cloud infrastructure to mobile apps and everything in between. outside of code, i write, produce and record music. feel free to reach out below!</p>
        </div>

        <div class="platform-card card-about card-about-stats" data-card="about">
          <h3 class="about-label">Stats</h3>
          <div class="stat-row">
            {stats.map((s) => (
              <div class="stat-tile">
                <span class="stat-value">{s.value}</span>
                <span class="stat-label">{s.label}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="platform-card card-about card-about-tech" data-card="about">
          <h3 class="about-label">Tech stack</h3>
          <ul class="chips">
            {tech.map((name) => (
              <li class="chip">{name}</li>
            ))}
          </ul>
        </div>

        <div class="platform-card card-about card-about-socials" data-card="about">
          <h3 class="about-label">Socials</h3>
          <div class="social-buttons">
            {socials.map(([name, href]) => (
              <a class="social-btn" href={href} target="_blank" rel="noopener noreferrer">{name}</a>
            ))}
          </div>
        </div>

        <div class="platform-card card-about card-about-cv" data-card="about">
          <h3 class="about-label">CV</h3>
          <a class="cv-btn" href="/downloads/resume.pdf" download>Click to download CV</a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style is:global>
  /* Poster framing: black title bar on top, the map fills the rest on a thin
     warm-gray mat. Map internals key off --bg = white. */
  body.home { overflow: hidden; --bg: #ffffff; background: #b3aca0; }
</style>

<style>
  .top-bar {
    position: relative;
    height: 74px;
    background: #000;
    display: flex;
    align-items: center;
    padding: 0 1.6rem;
  }
  .logo {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    color: #fff;
    text-decoration: none;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }
  .logo img { background: #fff; border-radius: 7px; padding: 3px; align-self: center; }
  .logo-name { font-weight: 800; font-size: 1.7rem; letter-spacing: 0.005em; }
  .logo-sub { font-weight: 300; font-size: 1.35rem; color: #d7d2c8; }
  /* Centered on the bar as a whole (not relative to the logo), so the
     platform label stays put regardless of logo width. */
  .bar-section {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    color: #fff;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-weight: 700;
    font-size: 1.5rem;
  }
  .bar-section:empty { display: none; }
  .map-stage {
    position: relative;
    height: calc(100vh - 74px);
    padding: 0;
  }
  .map-wrap {
    width: 100%;
    height: 100%;
    overflow: hidden;
  }
  @media (max-width: 768px) {
    .top-bar { height: 60px; }
    .logo-name { font-size: 1.3rem; }
    .logo-sub { font-size: 1.05rem; }
    .map-stage { height: calc(100dvh - 60px); padding: 0; }
    :global(#station-board) { right: 20px; top: auto; bottom: 20px; transform: none; }
  }

  /* ------------------------------------------------------------------ */
  /* Platform overlay: sits above the map panel, itself click-through   */
  /* except for its interactive children (the in-map engine drives its  */
  /* visibility/opacity/positioning; see src/scripts/ride.ts).          */
  #platform-ui {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 20;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  #back-map {
    position: absolute;
    top: 18px;
    left: 18px;
    pointer-events: auto;
    font: inherit;
    font-weight: 700;
    font-size: 0.95rem;
    color: #fff;
    background: #131313;
    border: none;
    border-radius: 999px;
    padding: 0.55rem 1.1rem;
    cursor: pointer;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
  }
  #back-map:hover { filter: brightness(1.15); }

  /* Edge paging buttons: vertically centered on the left/right edges of the
     map stage; the engine sets their background to the current line's hex. */
  .edge-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: auto;
    font: inherit;
    font-weight: 700;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.95rem;
    color: #fff;
    background: #131313;
    border: none;
    border-radius: 999px;
    padding: 0.65rem 1.2rem;
    cursor: pointer;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
    white-space: nowrap;
  }
  .edge-btn:hover { filter: brightness(1.12); }
  .edge-btn[hidden] { display: none; }
  .edge-btn-right { right: 22px; }
  .edge-btn-left { left: 22px; }

  /* Cards: absolutely positioned by the engine (left/top + GSAP transforms).
     No transform set here — GSAP owns it. */
  .platform-card {
    position: absolute;
    pointer-events: auto;
    background: #fff;
    border-radius: 10px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.22);
    padding: 0.7rem 0.85rem;
    box-sizing: border-box;
    text-decoration: none;
    color: inherit;
  }

  /* Music platform: full-width open rows instead of cards. The engine sets
     `left` per stop; `right: 4vw` lets each row's width flow to near the
     viewport edge. No card box, shadow, or radius — transparent rows over
     the map, separated by grid-line dividers. */
  .platform-row {
    position: absolute;
    pointer-events: auto;
    right: 4vw;
    box-sizing: border-box;
    background: transparent;
    box-shadow: none;
    border-radius: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 1.4rem;
    color: #1a1a1a;
  }
  .row-info { width: 240px; flex: none; min-width: 0; }
  .row-title { margin: 0; font-size: 1.15rem; font-weight: 700; line-height: 1.2; }
  .row-artist { margin: 0.2rem 0 0.4rem; font-size: 0.82rem; color: #6f6a60; font-weight: 600; }
  .row-links { display: flex; flex-wrap: wrap; gap: 0.6rem; font-size: 0.72rem; font-weight: 700; }
  .row-links a { color: #754fad; text-decoration: none; }
  .row-links a:hover { text-decoration: underline; }
  .row-wave { flex: 1 1 auto; min-width: 60px; height: 56px; display: block; }
  .row-meters { display: flex; gap: 0.6rem; align-items: flex-end; flex: none; }
  .meter-group { display: flex; flex-direction: column; align-items: center; gap: 0.25rem; }
  .meter-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: #6f6a60;
    text-transform: lowercase;
  }
  .row-freq { width: 280px; height: 110px; }
  .row-vec { width: 110px; height: 110px; }
  .row-vu { width: 76px; height: 110px; }
  .row-play {
    flex: none;
    font: inherit;
    font-weight: 700;
    font-size: 0.78rem;
    cursor: pointer;
    border: 1.5px solid #754fad;
    background: transparent;
    color: #754fad;
    border-radius: 999px;
    padding: 0.32rem 0.9rem;
  }
  .row-play[aria-pressed='true'] { background: #754fad; color: #fff; }

  /* Grid-line dividers: thin ink lines that read as the map's own grid
     fading in. The engine positions them at the midpoints between music
     stops (which fall on 50-unit grid lines). Same left→right span as rows. */
  .platform-divider {
    position: absolute;
    right: 4vw;
    height: 1px;
    background: rgba(26, 26, 26, 0.16);
    transform: translateY(-50%);
    pointer-events: none;
  }

  @media (max-width: 1180px) {
    .row-meters { display: none; }
    .row-info { width: 200px; }
  }

  /* Project cards: the engine positions the <a> itself with GSAP transforms
     (xPercent/x), so hover scale/shadow live on an inner wrapper instead —
     applying transform to the positioned element would fight GSAP. */
  .card-project {
    width: 360px;
    padding: 0;
    display: block;
    background: transparent;
    box-shadow: none;
    cursor: pointer;
  }
  .card-project .card-inner {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.22);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .card-project:hover .card-inner,
  .card-project:focus-visible .card-inner {
    transform: scale(1.04);
    box-shadow: 0 20px 46px rgba(0, 0, 0, 0.32);
  }
  .card-project .thumb { width: 100%; height: 170px; object-fit: cover; display: block; }
  .card-project .body { padding: 0.85rem 1.05rem 1.05rem; }
  .card-project h3 { margin: 0 0 0.3rem; font-size: 1.15rem; font-weight: 800; line-height: 1.2; }
  .card-project .summary {
    margin: 0 0 0.5rem;
    font-size: 0.88rem;
    color: #444;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-project .tags { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 0.3rem; }
  .card-project .tags li { font-size: 0.64rem; font-weight: 700; color: #d13d59; border: 1.2px solid #d13d59; border-radius: 999px; padding: 0.12rem 0.5rem; }

  /* Filter bar: horizontally centered above the platform line, projects
     view only (toggled in showUI/hideUI). */
  #filter-bar {
    position: absolute;
    top: 92px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.4rem;
    max-width: min(84vw, 760px);
    pointer-events: auto;
  }
  #filter-bar[hidden] { display: none; }
  .filter-tag {
    font: inherit;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-weight: 700;
    font-size: 0.72rem;
    color: #d13d59;
    background: rgba(255, 255, 255, 0.9);
    border: 1.2px solid #d13d59;
    border-radius: 999px;
    padding: 0.28rem 0.75rem;
    cursor: pointer;
  }
  .filter-tag.active,
  .filter-tag[aria-pressed='true'] {
    background: #d13d59;
    color: #fff;
  }
  .filter-tag:hover:not(.active) { background: rgba(209, 61, 89, 0.12); }

  .card-about {
    width: 400px;
  }
  /* The bio card carries a portrait photo + far more text than its
     siblings; it needs extra width so the text column wraps to fewer
     lines and the card stays short enough not to collide with the next
     stop's card on the diagonal about platform (5 stops). */
  .card-about-bio {
    width: 760px;
    display: flex;
    align-items: flex-start;
    gap: 0;
    padding: 0;
    overflow: hidden;
  }
  .about-label { margin: 0 0 0.4rem; font-size: 0.66rem; letter-spacing: 0.16em; text-transform: uppercase; color: #6f6a60; }
  .card-about-bio .photo {
    width: 38%;
    /* Fixed (not stretched to the text column's height): the photo is a
       portrait image, so letting it stretch/aspect-fit would make its
       intrinsic ratio dictate the whole card's height. Pin it instead so
       the text column's own content controls card height. */
    height: 150px;
    flex: none;
    object-fit: cover;
    display: block;
  }
  .card-about-bio .bio {
    margin: 0;
    padding: 0.85rem 1rem;
    font-size: 1.05rem;
    line-height: 1.65;
  }
  .stat-row { display: flex; gap: 0.5rem; }
  .stat-tile { flex: 1; background: #815e49; color: #fff; border-radius: 8px; padding: 0.5rem 0.6rem; display: flex; flex-direction: column; }
  .stat-value { font-size: 1.2rem; font-weight: 800; line-height: 1; }
  .stat-label { margin-top: 0.2rem; font-size: 0.68rem; opacity: 0.9; }
  .chips { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 0.3rem; }
  .chip { font-size: 0.64rem; font-weight: 700; border-radius: 999px; padding: 0.16rem 0.55rem; background: #eee7db; color: #3a352b; }
  .social-buttons { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .social-btn { text-decoration: none; font-weight: 700; font-size: 0.78rem; color: #fff; background: #815e49; border-radius: 8px; padding: 0.4rem 0.75rem; }
  .social-btn:hover { filter: brightness(1.12); }
  .cv-btn {
    display: block;
    text-align: center;
    text-decoration: none;
    font-weight: 800;
    font-size: 0.95rem;
    color: #fff;
    background: #815e49;
    border-radius: 8px;
    padding: 0.75rem 1rem;
  }
  .cv-btn:hover { filter: brightness(1.12); }
</style>

<script>
  import '../scripts/ride.ts';
  import '../scripts/music-player.ts';
</script>

<style is:global>
  /* fade target used by the ride timeline (GSAP autoAlpha needs a starting visibility) */
  #station-board { will-change: opacity; }
</style>
